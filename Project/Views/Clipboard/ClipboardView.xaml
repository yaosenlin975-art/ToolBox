<UserControl x:Class="ToolBox.Views.ClipboardHistory.ClipboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BgBrush}">
    <UserControl.Resources>
        <ItemsPanelTemplate x:Key="ClipboardListPanel">
            <StackPanel Orientation="Vertical"/>
        </ItemsPanelTemplate>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="32,24,32,8">
            <TextBlock Text="{DynamicResource Lang_Clipboard}" FontSize="22" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock x:Name="lblSubtitle" Text="{DynamicResource Lang_Loading}" FontSize="12" Margin="0,4,0,0"
                       Foreground="{DynamicResource TextTertiaryBrush}"/>
        </StackPanel>

        <!-- Toolbar -->
        <Border Grid.Row="1" Margin="32,0,32,0" Padding="0,12"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <!-- Type Filter -->
                <Border Background="{DynamicResource BgSunkenBrush}" CornerRadius="6" Padding="2"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="TypeAll" Content="{DynamicResource Lang_ClipTypeAll}" Style="{StaticResource DateFilterStyle}"
                                     Click="OnTypeFilterChanged" IsChecked="True" Margin="0,0,2,0"/>
                        <RadioButton x:Name="TypeText" Content="{DynamicResource Lang_ClipTypeText}" Style="{StaticResource DateFilterStyle}"
                                     Click="OnTypeFilterChanged" Margin="0,0,2,0"/>
                        <RadioButton x:Name="TypeImage" Content="{DynamicResource Lang_ClipTypeImage}" Style="{StaticResource DateFilterStyle}"
                                     Click="OnTypeFilterChanged" Margin="0,0,2,0"/>
                        <RadioButton x:Name="TypeFile" Content="{DynamicResource Lang_ClipTypeFile}" Style="{StaticResource DateFilterStyle}"
                                     Click="OnTypeFilterChanged"/>
                    </StackPanel>
                </Border>

                <Border Width="1" Margin="10,4" Background="{DynamicResource BorderBrush}"/>

                <!-- Date Filter -->
                <Border Background="{DynamicResource BgSunkenBrush}" CornerRadius="6" Padding="2"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="DateToday" Content="{DynamicResource Lang_DateToday}" Style="{StaticResource DateFilterStyle}"
                                     Click="OnDateFilterChanged" Margin="0,0,2,0"/>
                        <RadioButton x:Name="DateWeek" Content="{DynamicResource Lang_DateWeek}" Style="{StaticResource DateFilterStyle}"
                                     Click="OnDateFilterChanged" Margin="0,0,2,0"/>
                        <RadioButton x:Name="DateMonth" Content="{DynamicResource Lang_DateMonth}" Style="{StaticResource DateFilterStyle}"
                                     Click="OnDateFilterChanged" IsChecked="True" Margin="0,0,2,0"/>
                        <RadioButton x:Name="DateAll" Content="{DynamicResource Lang_DateAll}" Style="{StaticResource DateFilterStyle}"
                                     Click="OnDateFilterChanged"/>
                    </StackPanel>
                </Border>

                <Border Width="1" Margin="10,4" Background="{DynamicResource BorderBrush}"/>

                <!-- Search -->
                <Border Background="{DynamicResource BgSunkenBrush}" CornerRadius="6"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="8,4">
                    <TextBox x:Name="SearchBox" Background="Transparent" BorderThickness="0"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             CaretBrush="{DynamicResource AccentBrush}"
                             FontSize="13" MinWidth="200"
                             TextChanged="OnSearchTextChanged"/>
                </Border>

                <Border Width="1" Margin="10,4" Background="{DynamicResource BorderBrush}"/>

                <!-- Pause Monitor -->
                <Button x:Name="btnPauseMonitor" Content="{DynamicResource Lang_ClipPause5min}"
                        Style="{StaticResource OutlineButton}" Click="OnPauseMonitorClick"
                        Padding="12,4" FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- 列表 + 详情面板 -->
        <Grid Grid.Row="2" Margin="32,16,32,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧列表 -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,16,0">
                <ListBox x:Name="lstClipboard" Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ItemsPanel="{StaticResource ClipboardListPanel}"
                         SelectionChanged="OnEntrySelectionChanged"
                         MouseLeftButtonUp="OnEntryClicked">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource ModernListBoxItem}">
                            <Setter Property="Margin" Value="0,0,0,4"/>
                            <Setter Property="Padding" Value="12,8"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="40" Height="40"
                                        Background="{DynamicResource BgSunkenBrush}"
                                        CornerRadius="4" VerticalAlignment="Center">
                                    <Grid>
                                        <Image Source="{Binding ThumbnailPath}" Stretch="UniformToFill"
                                               Visibility="{Binding HasThumbnail, Converter={StaticResource BoolToVis}}"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                        <TextBlock Text="T" FontSize="13" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Visibility="{Binding IsTextType, Converter={StaticResource BoolToVis}}"/>
                                        <TextBlock Text="F" FontSize="13" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Visibility="{Binding IsFileListType, Converter={StaticResource BoolToVis}}"/>
                                    </Grid>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📌" FontSize="10" Margin="0,0,4,0"
                                                   Visibility="{Binding IsPinned, Converter={StaticResource BoolToVis}}"/>
                                        <TextBlock Text="★" FontSize="11" Margin="0,0,4,0"
                                                   Foreground="{Binding FavoriteColor}"
                                                   Visibility="{Binding IsFavorite, Converter={StaticResource BoolToVis}}"/>
                                        <TextBlock Text="{Binding DisplayTitle}" FontSize="13" FontWeight="Medium"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding TimeDisplay}" FontSize="11" Margin="0,2,0,0"
                                               Foreground="{DynamicResource TextTertiaryBrush}"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="{Binding TypeBadge}" FontSize="11"
                                           Foreground="{DynamicResource TextTertiaryBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>

            <!-- 右侧详情面板 -->
            <Border Grid.Column="1" Background="{DynamicResource BgElevatedBrush}"
                    BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="16">
                <Grid x:Name="DetailPanel">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <!-- 占位 -->
                    <TextBlock x:Name="lblDetailEmpty" Grid.Row="0" Grid.RowSpan="4"
                               Text="{DynamicResource Lang_ClipSelectEntry}"
                               FontSize="13" Foreground="{DynamicResource TextTertiaryBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <StackPanel x:Name="DetailContent" Grid.Row="0" Visibility="Collapsed">
                        <TextBlock x:Name="lblDetailTitle" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="lblDetailMeta" FontSize="11" Margin="0,4,0,0"
                                   Foreground="{DynamicResource TextTertiaryBrush}"/>
                    </StackPanel>
                    <Border x:Name="DetailImage" Grid.Row="1" Margin="0,12"
                            Background="{DynamicResource BgSunkenBrush}"
                            CornerRadius="4" Visibility="Collapsed">
                        <Image x:Name="imgDetail" Stretch="Uniform" Margin="4"/>
                    </Border>
                    <ScrollViewer Grid.Row="2" Margin="0,12,0,0" VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="lblDetailText" FontSize="13" TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </ScrollViewer>
                    <StackPanel x:Name="DetailActions" Grid.Row="3" Orientation="Horizontal" Margin="0,12,0,0">
                        <Button x:Name="btnCopy" Content="{DynamicResource Lang_ClipCopy}" Style="{StaticResource BtnDefault}"
                                Padding="14,6" FontSize="12" Click="OnDetailCopyClick"/>
                        <Button x:Name="btnFavorite" Content="{DynamicResource Lang_ClipFavorite}" Style="{StaticResource OutlineButton}"
                                Padding="14,6" FontSize="12" Click="OnDetailFavoriteClick" Margin="8,0,0,0"/>
                        <Button x:Name="btnPin" Content="{DynamicResource Lang_ClipPin}" Style="{StaticResource OutlineButton}"
                                Padding="14,6" FontSize="12" Click="OnDetailPinClick" Margin="8,0,0,0"/>
                        <Button x:Name="btnDelete" Content="{DynamicResource Lang_ClipDelete}" Style="{StaticResource OutlineButton}"
                                Padding="14,6" FontSize="12" Click="OnDetailDeleteClick" Margin="8,0,0,0"/>
                        <Button x:Name="btnSendToAi" Content="{DynamicResource Lang_ClipSendToAi}" Style="{StaticResource BtnPrimary}"
                                Padding="14,6" FontSize="12" Click="OnDetailSendToAiClick" Margin="8,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Bottom Bar -->
        <Border Grid.Row="3" Padding="32,12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="btnLoadMore" Content="{DynamicResource Lang_LoadMore}" Click="OnLoadMoreClick"
                        Style="{StaticResource OutlineButton}" Padding="20,6" FontSize="12"
                        Visibility="Collapsed"/>
                <TextBlock x:Name="lblEmpty" Text="{DynamicResource Lang_NoHistory}" Margin="0,0,0,0"
                           Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12"
                           Visibility="Collapsed"/>
                <TextBlock x:Name="lblStatus" Margin="12,0,0,0"
                           Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
