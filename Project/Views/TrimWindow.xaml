<Window x:Class="ToolBox.Views.TrimWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="裁剪" Height="600" Width="800"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#80000000">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Canvas x:Name="canvas" Grid.Row="0"
                MouseLeftButtonDown="OnCanvasMouseDown"
                MouseMove="OnCanvasMouseMove"
                MouseLeftButtonUp="OnCanvasMouseUp">
            <Image x:Name="previewImage" Canvas.Left="10" Canvas.Top="10"/>
            <Rectangle x:Name="selectionRect" Stroke="Blue" StrokeThickness="2"
                       Fill="#4D0000FF" Visibility="Collapsed"/>
        </Canvas>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button Content="取消" Click="BtnCancel_Click" Width="80"/>
        </StackPanel>
    </Grid>
</Window>
