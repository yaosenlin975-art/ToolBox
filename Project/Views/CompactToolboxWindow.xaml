<Window x:Class="ToolBox.Views.CompactToolboxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:chat="clr-namespace:ToolBox.Views.Chat"
        Title="ToolBox" Width="320" Height="320" MinWidth="280" MinHeight="240"
        WindowStartupLocation="Manual" Topmost="True"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ShowInTaskbar="False">
    <Window.Resources>
        <Style x:Key="CompactTabButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextTertiaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgHoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CompactTabButtonActive" TargetType="Button" BasedOn="{StaticResource CompactTabButton}">
            <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
        </Style>

        <Style x:Key="CompactIconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextTertiaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgHoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder" Background="{DynamicResource BgElevatedBrush}" CornerRadius="14"
            BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 顶栏:展开按钮 + Tab 组 + 三横线设置 -->
            <Border Grid.Row="0" Padding="8,4" Background="Transparent"
                    CornerRadius="14,14,0,0" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="ExpandToggleBtn" Grid.Column="0" Content="▲"
                            Style="{StaticResource CompactIconButton}" Click="ExpandToggleBtn_Click" ToolTip="打开工作台"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button x:Name="TabTodo" Content="待办" Style="{StaticResource CompactTabButtonActive}" Click="Tab_Click" Tag="todo"/>
                        <Button x:Name="TabChat" Content="助手" Style="{StaticResource CompactTabButton}" Click="Tab_Click" Tag="chat"/>
                        <Button x:Name="TabHistory" Content="历史" Style="{StaticResource CompactTabButton}" Click="Tab_Click" Tag="history"/>
                    </StackPanel>
                    <Button x:Name="BtnSettings" Grid.Column="2" Content="≡"
                            Style="{StaticResource CompactIconButton}" Click="BtnSettings_Click" ToolTip="设置" FontSize="16"/>
                </Grid>
            </Border>

            <!-- 会话切换行(仅 chat tab 显示,顶栏下方独立一行) -->
            <Border Grid.Row="1" x:Name="SessionRow" Padding="8,4" Background="{DynamicResource BgSunkenBrush}"
                    BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,0,0,1" Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="SessionSelector" Grid.Column="0" Height="24" FontSize="11"
                              Background="{DynamicResource BgElevatedBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                              BorderBrush="{DynamicResource BorderDefaultBrush}" DisplayMemberPath="Title"
                              SelectionChanged="SessionSelector_SelectionChanged"/>
                    <Button x:Name="NewSessionBtn" Grid.Column="1" Content="+" Style="{StaticResource CompactIconButton}"
                            Click="NewSessionBtn_Click" ToolTip="新建会话"/>
                </Grid>
            </Border>

            <!-- 内容区 -->
            <Grid Grid.Row="2">
                <!-- 迷你待办:仅未完成项列表 + 右下角 + 按钮 -->
                <Grid x:Name="TodoPanel" Visibility="Visible">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8,4">
                        <ItemsControl x:Name="TodoList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,3">
                                        <CheckBox IsChecked="{Binding IsCompleted}" Tag="{Binding Id}"
                                                  Checked="TodoItem_Changed" Unchecked="TodoItem_Changed"/>
                                        <TextBlock Text="{Binding Title}" FontSize="12" Margin="6,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Bottom"
                            Margin="0,0,8,8" Width="32" Height="32"
                            Style="{StaticResource CompactIconButton}" Content="+"
                            Click="QuickAddTodo_Click" ToolTip="快速添加" FontSize="18"
                            Background="{DynamicResource AccentSoftBrush}"
                            Foreground="{DynamicResource AccentBrush}"/>
                </Grid>

                <!-- 助手:ChatView compact 模式(自带隐藏侧栏) -->
                <chat:ChatView x:Name="ChatPanel" Visibility="Collapsed" IsCompactMode="True"/>

                <!-- 迷你历史:垂直滚动列表,最近 10 张 -->
                <ScrollViewer x:Name="HistoryPanel" Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto" Padding="8,4">
                    <ItemsControl x:Name="HistoryList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,3">
                                    <Image Source="{Binding Thumbnail}" Width="56" Height="40" Stretch="UniformToFill"/>
                                    <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding TimeDisplay}" FontSize="11"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding SizeDisplay}" FontSize="10"
                                                   Foreground="{DynamicResource TextTertiaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>
