<Window x:Class="ToolBox.Views.Capture.CaptureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        WindowState="Maximized"
        Topmost="True"
        AllowsTransparency="True"
        Background="#40000000"
        ShowInTaskbar="False">
    <Canvas x:Name="overlayCanvas" Cursor="Cross">
        <Canvas.InputBindings>
            <KeyBinding Key="Escape" Command="{x:Static ApplicationCommands.Close}"/>
        </Canvas.InputBindings>
        <Image x:Name="previewImage" Canvas.Left="0" Canvas.Top="0"
               RenderOptions.BitmapScalingMode="NearestNeighbor"/>
        <Rectangle x:Name="selectionRect" Stroke="#E8734A" StrokeThickness="2"
                   Fill="#20E8734A" Visibility="Collapsed"/>
    </Canvas>
</Window>

