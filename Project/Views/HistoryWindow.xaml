<Window x:Class="ToolBox.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Screenshot History" Height="600" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource BgPrimaryBrush}">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Margin="20,20,20,0">
            <TextBlock Text="Screenshot History" FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock x:Name="lblSubtitle" Text="Loading..." FontSize="12"
                       Foreground="{StaticResource TextTertiaryBrush}" Margin="0,2,0,0"/>
        </StackPanel>
        <ListBox x:Name="lstHistory" Grid.Row="1" BorderThickness="0"
                 Background="Transparent" Margin="12,12,12,0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1"
                            CornerRadius="10" Padding="12" Margin="0,0,0,6"
                            Background="{StaticResource BgSecondaryBrush}" Cursor="Hand">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding DataContext.LoadCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                          CommandParameter="{Binding}"/>
                        </Border.InputBindings>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="64" Height="48" CornerRadius="6"
                                    BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1"
                                    ClipToBounds="True" Margin="0,0,12,0">
                                <Image Source="{Binding Thumbnail}" Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Left">
                                <TextBlock Text="{Binding TimeDisplay}" FontWeight="Medium"
                                           FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Foreground="{StaticResource TextTertiaryBrush}" FontSize="11"
                                           Margin="0,2,0,0">
                                    <Run Text="{Binding SizeDisplay, Mode=OneWay}"/>
                                    <Run Text=" · "/>
                                    <Run Text="{Binding PositionDisplay, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                                <Button Content="↗" ToolTip="Load" Width="28" Height="28"
                                        Style="{StaticResource BtnDefault}" FontSize="12"
                                        Command="{Binding DataContext.LoadCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}" Padding="0"/>
                                <Button Content="✕" ToolTip="Delete" Width="28" Height="28"
                                        Style="{StaticResource BtnDefault}" FontSize="12"
                                        Foreground="{StaticResource DangerBrush}" Padding="0" Margin="4,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <StackPanel Grid.Row="2" Orientation="Vertical" HorizontalAlignment="Center" Margin="0,12,0,20">
            <Button x:Name="btnLoadMore" Content="Load More ↓" Click="BtnLoadMore_Click"
                    Style="{StaticResource BtnDefault}" Width="140" Height="34" Visibility="Collapsed"/>
            <TextBlock x:Name="lblEmpty" Text="No history yet" HorizontalAlignment="Center"
                       Foreground="{StaticResource TextTertiaryBrush}" Visibility="Collapsed" Margin="0,8,0,0"/>
            <TextBlock x:Name="lblCount" Text="" HorizontalAlignment="Center"
                       Foreground="{StaticResource TextTertiaryBrush}" FontSize="11" Margin="0,8,0,0"/>
        </StackPanel>
    </Grid>
</Window>
