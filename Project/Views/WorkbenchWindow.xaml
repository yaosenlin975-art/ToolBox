<Window x:Class="ToolBox.Views.WorkbenchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:ToolBox.Views.Shell"
        Title="ToolBox" Width="1440" Height="900"
        WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="CenterScreen" Background="Transparent"
        ShowInTaskbar="True">
    <Border Background="{DynamicResource BgBrush}"
            BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1"
            CornerRadius="{StaticResource RadiusLg}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="12" Opacity="0.18" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Background="{DynamicResource BgElevatedBrush}"
                  MouseLeftButtonDown="OnTitleBarMouseDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="ToolBox" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" Margin="16,0,0,0"/>
                <TextBlock Grid.Column="1" x:Name="PageTitle" FontSize="12"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,8,0">
                    <Button x:Name="BtnCompact" Width="32" Height="32" Style="{StaticResource IconButton}"
                            Click="OnSwitchToCompact" Content="&#xE73F;" FontFamily="Segoe MDL2 Assets" FontSize="11" ToolTip="切换到迷你模式"/>
                    <Button x:Name="BtnMinimize" Width="32" Height="32" Style="{StaticResource IconButton}"
                            Click="OnMinimize" Content="&#xE949;" FontFamily="Segoe MDL2 Assets" FontSize="10" ToolTip="最小化"/>
                    <Button x:Name="BtnMaximize" Width="32" Height="32" Style="{StaticResource IconButton}"
                            Click="OnMaximize" Content="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="10" ToolTip="最大化/还原"/>
                    <Button x:Name="BtnClose" Width="32" Height="32" Style="{StaticResource IconButton}"
                            Click="OnClose" Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10" ToolTip="关闭"/>
                </StackPanel>
            </Grid>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <shell:Sidebar x:Name="TheSidebar" Grid.Column="0"/>
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <shell:TopHeader x:Name="TheHeader" Grid.Row="0"/>
                    <ContentControl x:Name="PageHost" Grid.Row="1"/>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
