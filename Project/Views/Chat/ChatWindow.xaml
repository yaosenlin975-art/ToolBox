<Window x:Class="ToolBox.Views.Chat.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ToolBox.Views.Chat"
        Title="ToolBox AI 助手" Height="650" Width="850"
        WindowStartupLocation="CenterScreen" Background="{StaticResource ChatBgBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <local:SessionSidebar x:Name="Sidebar" Grid.Column="0"
                              SessionSelected="Sidebar_SessionSelected"
                              NewSessionRequested="Sidebar_NewSessionRequested"/>

        <!-- Chat Area -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Messages -->
            <ScrollViewer x:Name="MessageScroller" Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="0,12,0,0">
                <StackPanel x:Name="MessagePanel" Orientation="Vertical"/>
            </ScrollViewer>

            <!-- Input Area -->
            <Border Grid.Row="1" Padding="12,8" BorderBrush="{StaticResource ChatInputBorderBrush}" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBox x:Name="InputBox" Grid.Row="0" 
                             AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="120"
                             FontSize="13" Padding="10,8" 
                             Background="{StaticResource ChatInputBgBrush}"
                             BorderBrush="{StaticResource ChatInputBorderBrush}"
                             BorderThickness="1" VerticalContentAlignment="Top"
                             KeyDown="InputBox_KeyDown" TextChanged="InputBox_TextChanged"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                        <TextBlock x:Name="StatusText" Text="就绪" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Button x:Name="SendBtn" Content="发送" Padding="16,6" FontSize="13"
                                Style="{StaticResource BtnDefault}" IsEnabled="False" Click="SendBtn_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
