<UserControl x:Class="ToolBox.Views.Chat.ToolCallCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Margin="16,4" MaxWidth="500" HorizontalAlignment="Left">
    <Border Background="{StaticResource ChatBgToolBrush}" CornerRadius="6" Padding="10,8">
        <StackPanel>
            <Button x:Name="ToggleBtn" HorizontalAlignment="Left" Background="Transparent" BorderThickness="0"
                    Click="ToggleBtn_Click" Cursor="Hand" Padding="0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔧" FontSize="12" Margin="0,0,4,0"/>
                    <TextBlock x:Name="ToolNameText" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource ChatTextToolBrush}"/>
                    <TextBlock x:Name="StatusIcon" Text=" ▸" FontSize="11" Foreground="{StaticResource ChatTextToolBrush}" Margin="4,0,0,0"/>
                </StackPanel>
            </Button>
            <Border x:Name="DetailPanel" Visibility="Collapsed" Margin="0,6,0,0" Background="{StaticResource ChatBgSecondaryBrush}" CornerRadius="4" Padding="8">
                <StackPanel>
                    <TextBlock x:Name="ArgsText" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" FontFamily="Consolas"/>
                    <TextBlock x:Name="ResultText" FontSize="11" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap" Margin="0,6,0,0" FontFamily="Consolas"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
