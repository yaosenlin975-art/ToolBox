<UserControl x:Class="ToolBox.Views.Chat.ChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid x:Name="RootGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 会话侧边栏 -->
        <Border x:Name="SidebarBorder" Grid.Column="0"
                Background="{DynamicResource BgElevatedBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Padding="16,14" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                    <Grid>
                        <TextBlock Text="会话" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <Button x:Name="NewSessionBtn" HorizontalAlignment="Right" Width="28" Height="28"
                                Style="{StaticResource IconButton}" Click="NewSessionBtn_Click" ToolTip="新建会话"
                                Content="+"/>
                    </Grid>
                </Border>
                <ListBox x:Name="SessionList" Grid.Row="1" Background="Transparent" BorderThickness="0"
                         Padding="6,6,6,6" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         SelectionChanged="SessionList_SelectionChanged">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,2"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" Background="Transparent" CornerRadius="6"
                                                Padding="10,8" Cursor="Hand">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background"
                                                        Value="{DynamicResource BgSunkenBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background"
                                                        Value="{DynamicResource BgSunkenBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📌" FontSize="10" Margin="0,0,4,0"
                                               Foreground="{DynamicResource AccentBrush}"
                                               Visibility="{Binding IsPinned, Converter={StaticResource BoolToVis}}"/>
                                    <TextBlock Text="{Binding Title}" FontSize="13" TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>
                                <TextBlock Text="{Binding UpdatedAtLocal, StringFormat='{}{0:MM-dd HH:mm}'}"
                                           FontSize="11" Margin="0,2,0,0"
                                           Foreground="{DynamicResource TextTertiaryBrush}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- 对话区 -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer x:Name="MessageScroller" Grid.Row="0"
                          VerticalScrollBarVisibility="Auto" Padding="24,16,24,8">
                <StackPanel x:Name="MessagePanel" Orientation="Vertical"/>
            </ScrollViewer>

            <Border Grid.Row="1" Padding="16,12"
                    Background="{DynamicResource BgBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" CornerRadius="10"
                            Background="{DynamicResource BgSunkenBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                        <TextBox x:Name="InputBox" AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="120"
                                 FontSize="13" Padding="12,10" Background="Transparent" BorderThickness="0"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 CaretBrush="{DynamicResource AccentBrush}"
                                 VerticalContentAlignment="Top"
                                 KeyDown="InputBox_KeyDown" TextChanged="InputBox_TextChanged"/>
                    </Border>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <TextBlock x:Name="StatusText" Text="就绪" FontSize="11"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Button x:Name="SendBtn" Content="发送" Padding="18,8" FontSize="13"
                                Style="{StaticResource BtnPrimary}" IsEnabled="False"
                                Click="SendBtn_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
