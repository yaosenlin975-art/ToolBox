<UserControl x:Class="ToolBox.Views.Chat.SessionSidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="220" Background="{StaticResource ChatSidebarBgBrush}"
             xmlns:local="clr-namespace:ToolBox.Views.Chat">
    <UserControl.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="14,12" BorderBrush="{StaticResource ChatSidebarBorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="会话" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                <Button x:Name="NewSessionBtn" Grid.Column="1" Content="+" HorizontalAlignment="Right"
                        Width="30" Height="30" FontSize="18" Padding="0"
                        Style="{StaticResource BtnDefault}" Click="NewSessionBtn_Click" ToolTip="新建会话"/>
            </Grid>
        </Border>

        <ListBox x:Name="SessionList" Grid.Row="1"
                 Background="Transparent" BorderThickness="0"
                 SelectionChanged="SessionList_SelectionChanged">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="10,8" Margin="2,1" CornerRadius="4" Cursor="Hand" Background="Transparent"
                            MouseRightButtonUp="SessionItem_RightClick">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📌" FontSize="10" Margin="0,0,4,0"
                                           Foreground="{StaticResource AccentBrush}"
                                           Visibility="{Binding IsPinned, Converter={StaticResource BoolToVis}}"/>
                                <TextBlock Text="{Binding Title}" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <TextBlock Text="{Binding UpdatedAtLocal, StringFormat='{}{0:MM-dd HH:mm}'}" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
