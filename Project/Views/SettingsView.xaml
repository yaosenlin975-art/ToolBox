<UserControl x:Class="ToolBox.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BgBrush}">
    <UserControl.Resources>
        <!-- ── Settings Nav Item (左侧 200px 导航) ── -->
        <Style x:Key="SettingsNavItem" TargetType="RadioButton">
            <Setter Property="FontFamily" Value="{StaticResource FontSans}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,1,0,0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bg" Background="Transparent"
                                BorderBrush="Transparent" BorderThickness="3,0,0,0"
                                CornerRadius="{StaticResource RadiusSm}" Padding="9,10,12,10">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="icon" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                           Foreground="{TemplateBinding Foreground}" Opacity="0.7"
                                           VerticalAlignment="Center" Margin="0,0,10,0"
                                           Text="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource BgHoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                <Setter TargetName="icon" Property="Opacity" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource AccentSoftBrush}"/>
                                <Setter TargetName="bg" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                <Setter TargetName="icon" Property="Opacity" Value="1"/>
                                <Setter TargetName="icon" Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Toggle Switch (40×22,自实现) ── -->
        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="track" Background="{DynamicResource BorderStrongBrush}"
                                CornerRadius="{StaticResource RadiusFull}">
                            <Grid>
                                <Border x:Name="thumbOff" Width="16" Height="16" CornerRadius="8"
                                        Background="{DynamicResource TextPrimaryBrush}"
                                        HorizontalAlignment="Left" VerticalAlignment="Center" Margin="3,0,0,0"/>
                                <Border x:Name="thumbOn" Width="16" Height="16" CornerRadius="8"
                                        Background="White"
                                        HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,3,0"
                                        Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="track" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="thumbOff" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="thumbOn" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Radio Card (卡片式单选,用于运行模式/主题) ── -->
        <Style x:Key="RadioCard" TargetType="RadioButton">
            <Setter Property="FontFamily" Value="{StaticResource FontSans}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="card" Background="Transparent"
                                BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1"
                                CornerRadius="{StaticResource RadiusMd}" Padding="16,8">
                            <StackPanel Orientation="Horizontal">
                                <Border x:Name="dot" Width="16" Height="16" CornerRadius="8"
                                        BorderBrush="{DynamicResource BorderStrongBrush}" BorderThickness="2"
                                        Background="Transparent" VerticalAlignment="Center" Margin="0,0,10,0">
                                    <Ellipse x:Name="dotFill" Width="6" Height="6" Fill="{DynamicResource AccentBrush}"
                                             Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="card" Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="card" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="card" Property="Background" Value="{DynamicResource AccentSoftBrush}"/>
                                <Setter TargetName="dot" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="dotFill" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Settings Section (卡片容器) ── -->
        <Style x:Key="SettingsSection" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="{StaticResource RadiusLg}"/>
            <Setter Property="Padding" Value="{StaticResource Space6}"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>

        <!-- ── Setting Row (左 info / 右 control) ── -->
        <Style x:Key="SettingRow" TargetType="Grid">
            <Setter Property="Margin" Value="0,12"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Settings Layout ── -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Settings Nav (200px) ── -->
            <Border Grid.Column="0" Background="{DynamicResource BgBrush}"
                    BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,0,1,0">
                <StackPanel Margin="0,24,0,0">
                    <TextBlock Text="设置" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextTertiaryBrush}"
                               Margin="20,0,0,0" TextOptions.TextFormattingMode="Display">
                        <TextBlock.LayoutTransform><ScaleTransform ScaleX="1" ScaleY="1"/></TextBlock.LayoutTransform>
                    </TextBlock>
                    <StackPanel Margin="8,20,8,0">
                        <RadioButton x:Name="NavGeneral" GroupName="SettingsNav" IsChecked="True"
                                     Style="{StaticResource SettingsNavItem}" Tag="&#xE713;" Content="常规" Checked="OnNavChecked"/>
                        <RadioButton x:Name="NavHotKey" GroupName="SettingsNav"
                                     Style="{StaticResource SettingsNavItem}" Tag="&#xE765;" Content="快捷键" Checked="OnNavChecked"/>
                        <RadioButton x:Name="NavCapture" GroupName="SettingsNav"
                                     Style="{StaticResource SettingsNavItem}" Tag="&#xE722;" Content="截图" Checked="OnNavChecked"/>
                        <RadioButton x:Name="NavLlm" GroupName="SettingsNav"
                                     Style="{StaticResource SettingsNavItem}" Tag="&#xE8BD;" Content="LLM" Checked="OnNavChecked"/>
                        <RadioButton x:Name="NavSchedule" GroupName="SettingsNav"
                                     Style="{StaticResource SettingsNavItem}" Tag="&#xE823;" Content="定时" Checked="OnNavChecked"/>
                        <RadioButton x:Name="NavLanguage" GroupName="SettingsNav"
                                     Style="{StaticResource SettingsNavItem}" Tag="&#xE774;" Content="语言" Checked="OnNavChecked"/>
                        <RadioButton x:Name="NavAbout" GroupName="SettingsNav"
                                     Style="{StaticResource SettingsNavItem}" Tag="&#xE946;" Content="关于" Checked="OnNavChecked"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ── Settings Content ── -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="32,24,32,24">
                <StackPanel>
                    <StackPanel x:Name="SectionGeneral" Margin="0,0,0,8">
                        <TextBlock Text="常规设置" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="配置应用的基本行为和外观" FontSize="13" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,4,0,20"/>

                        <!-- Section: 应用模式 -->
                        <Border Style="{StaticResource SettingsSection}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource AccentBrush}"
                                               Text="&#xE7F4;" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="应用模式" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>

                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="运行模式" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="选择应用在系统中的运行方式" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <RadioButton x:Name="rdoAppMode" GroupName="AppMode" Style="{StaticResource RadioCard}" IsChecked="True">
                                            <StackPanel>
                                                <TextBlock Text="应用模式" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock Text="窗口可关闭，后台不常驻" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}"/>
                                            </StackPanel>
                                        </RadioButton>
                                        <RadioButton x:Name="rdoResidentMode" GroupName="AppMode" Style="{StaticResource RadioCard}">
                                            <StackPanel>
                                                <TextBlock Text="常驻模式" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock Text="最小化到系统托盘常驻" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}"/>
                                            </StackPanel>
                                        </RadioButton>
                                    </StackPanel>
                                </Grid>

                                <Border BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,1,0,0"/>

                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="开机自启" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="系统启动时自动运行 ToolBox" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <CheckBox x:Name="chkAutoStartup" Grid.Column="1" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center"/>
                                </Grid>

                                <Border BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,1,0,0"/>

                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="主题" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="选择界面主题（实时切换）" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <RadioButton x:Name="rdoThemeLight" GroupName="Theme" Style="{StaticResource RadioCard}" Checked="OnThemeChecked">
                                            <TextBlock Text="Light" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        </RadioButton>
                                        <RadioButton x:Name="rdoThemeDark" GroupName="Theme" Style="{StaticResource RadioCard}" Checked="OnThemeChecked">
                                            <TextBlock Text="Dark" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        </RadioButton>
                                        <RadioButton x:Name="rdoThemeSystem" GroupName="Theme" Style="{StaticResource RadioCard}" Checked="OnThemeChecked">
                                            <TextBlock Text="System" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        </RadioButton>
                                    </StackPanel>
                                </Grid>

                                <Border BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,1,0,0"/>

                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="迷你窗口透明度" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="调整迷你模式窗口背景透明度（实时预览）" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Width="280">
                                        <Slider x:Name="sldCompactOpacity" Style="{StaticResource ModernSlider}" Width="220"
                                                Minimum="0" Maximum="100" VerticalAlignment="Center"
                                                ValueChanged="SldCompactOpacity_ValueChanged"/>
                                        <TextBlock x:Name="txtCompactOpacityValue" Text="50" FontSize="11" FontFamily="{StaticResource FontMono}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" MinWidth="36" TextAlignment="Right" Margin="12,0,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- ── Section: 快捷键 ── -->
                    <StackPanel x:Name="SectionHotKey" Visibility="Collapsed" Margin="0,0,0,8">
                        <TextBlock Text="快捷键" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="配置全局热键" FontSize="13" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,4,0,20"/>

                        <Border Style="{StaticResource SettingsSection}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource AccentBrush}"
                                               Text="&#xE765;" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="全局热键" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>

                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="启用全局热键" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="开启后可使用快捷键触发截图/显示隐藏" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <CheckBox x:Name="chkHotKeyEnable" Grid.Column="1" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center"/>
                                </Grid>

                                <Border BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,1,0,0"/>

                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="截图" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="点击右侧框,按下快捷键组合直接录入" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <TextBox x:Name="txtHotKey1" Grid.Column="1" Width="160" IsReadOnly="True"
                                             Text="Ctrl+1" FontSize="13" FontFamily="{StaticResource FontMono}"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             Background="{DynamicResource BgSunkenBrush}"
                                             BorderBrush="{DynamicResource BorderDefaultBrush}"
                                             CaretBrush="{DynamicResource TextPrimaryBrush}"
                                             PreviewKeyDown="HotKey_PreviewKeyDown"
                                             GotFocus="HotKey_GotFocus"
                                             LostFocus="HotKey_LostFocus"
                                             ToolTip="点击聚焦后按下快捷键组合"/>
                                </Grid>

                                <Border BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,1,0,0"/>

                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="显示/隐藏" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="点击右侧框,按下快捷键组合直接录入" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <TextBox x:Name="txtHotKey2" Grid.Column="1" Width="160" IsReadOnly="True"
                                             Text="Ctrl+2" FontSize="13" FontFamily="{StaticResource FontMono}"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             Background="{DynamicResource BgSunkenBrush}"
                                             BorderBrush="{DynamicResource BorderDefaultBrush}"
                                             CaretBrush="{DynamicResource TextPrimaryBrush}"
                                             PreviewKeyDown="HotKey_PreviewKeyDown"
                                             GotFocus="HotKey_GotFocus"
                                             LostFocus="HotKey_LostFocus"
                                             ToolTip="点击聚焦后按下快捷键组合"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- ── Section: 截图 ── -->
                    <StackPanel x:Name="SectionCapture" Visibility="Collapsed" Margin="0,0,0,8">
                        <TextBlock Text="截图设置" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="调整截图行为" FontSize="13" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,4,0,20"/>

                        <Border Style="{StaticResource SettingsSection}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource AccentBrush}"
                                               Text="&#xE722;" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="截图" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>

                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="选区透明度" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="截图选区遮罩的透明程度" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Width="280">
                                        <Slider x:Name="sldAreaTransparent" Style="{StaticResource ModernSlider}" Width="220"
                                                Minimum="0" Maximum="255" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="txtAreaTransparentValue" Text="80" FontSize="11" FontFamily="{StaticResource FontMono}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" MinWidth="36" TextAlignment="Right" Margin="12,0,0,0"/>
                                    </StackPanel>
                                </Grid>

                                <Border BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,1,0,0"/>

                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="选区边框样式" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="截图时选区的边框显示方式" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <RadioButton x:Name="rdoLineSolid" GroupName="LineStyle" Content="实线" Style="{StaticResource ModernRadioButton}" Margin="0,0,16,0"/>
                                        <RadioButton x:Name="rdoLineDotted" GroupName="LineStyle" Content="虚线" Style="{StaticResource ModernRadioButton}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- ── Section: LLM ── -->
                    <StackPanel x:Name="SectionLlm" Visibility="Collapsed" Margin="0,0,0,8">
                        <TextBlock Text="LLM 助手" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="配置大语言模型供应商" FontSize="13" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,4,0,20"/>

                        <Border Style="{StaticResource SettingsSection}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource AccentBrush}"
                                               Text="&#xE8BD;" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="供应商配置" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>

                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="供应商" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="cmbProvider" Grid.Column="1" Width="240" HorizontalAlignment="Left" SelectionChanged="CmbProvider_SelectionChanged"/>
                                </Grid>

                                <Border BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,1,0,0"/>

                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="模型" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <ComboBox x:Name="cmbModel" Width="240" HorizontalAlignment="Left"/>
                                        <Button x:Name="btnDiscoverModels" Content="发现模型" Style="{StaticResource OutlineButton}" Click="DiscoverModels_Click" Margin="8,0,0,0" Padding="10,4" FontSize="12"/>
                                    </StackPanel>
                                </Grid>

                                <Border BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,1,0,0"/>

                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="API Key" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                    <PasswordBox x:Name="txtApiKey" Grid.Column="1" Width="320" HorizontalAlignment="Left"/>
                                </Grid>

                                <Border BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,1,0,0"/>

                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Base URL" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                    <TextBox x:Name="txtBaseUrl" Grid.Column="1" Width="320" HorizontalAlignment="Left" Style="{StaticResource InputField}"/>
                                </Grid>

                                <Border BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,1,0,0"/>

                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="测试连接" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="测试" Style="{StaticResource OutlineButton}" Click="TestConnection_Click" Width="80" HorizontalAlignment="Left" Padding="0,5"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- ── Section: 定时 ── -->
                    <StackPanel x:Name="SectionSchedule" Visibility="Collapsed" Margin="0,0,0,8">
                        <TextBlock Text="定时截图与日报" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="配置自动截图和每日行为总结" FontSize="13" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,4,0,20"/>

                        <Border Style="{StaticResource SettingsSection}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource AccentBrush}"
                                               Text="&#xE823;" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="定时任务" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>

                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="定时全屏截图" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="按 Cron 表达式定时截取全屏" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <CheckBox x:Name="chkAutoScreenshot" Grid.Column="1" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center"/>
                                </Grid>

                                <Border BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,1,0,0"/>

                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Cron 表达式" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="分钟级: 分 时 日 月 周（例: 0 */30 * * * *）" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <TextBox x:Name="txtAutoScreenshotCron" Grid.Column="1" Width="200" HorizontalAlignment="Right" Style="{StaticResource InputField}"/>
                                </Grid>

                                <Border BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,1,0,0"/>

                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="每日行为总结" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="根据当日截图生成日报" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <CheckBox x:Name="chkDailyReport" Grid.Column="1" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center"/>
                                </Grid>

                                <Border BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,1,0,0"/>

                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="总结时间" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="格式: HH:mm，例 18:00" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <TextBox x:Name="txtDailyReportTime" Grid.Column="1" Width="120" HorizontalAlignment="Right" Style="{StaticResource InputField}"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- ── Section: 语言 ── -->
                    <StackPanel x:Name="SectionLanguage" Visibility="Collapsed" Margin="0,0,0,8">
                        <TextBlock Text="语言" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="选择界面语言（更改后重启生效）" FontSize="13" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,4,0,20"/>

                        <Border Style="{StaticResource SettingsSection}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource AccentBrush}"
                                               Text="&#xE774;" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="界面语言" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>

                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="语言" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="更改后需要重启应用生效" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <RadioButton x:Name="rdoLangZh" GroupName="Lang" Content="中文" Style="{StaticResource RadioCard}" Margin="0,0,12,0"/>
                                        <RadioButton x:Name="rdoLangEn" GroupName="Lang" Content="English" Style="{StaticResource RadioCard}" Margin="0"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- ── Section: 关于 ── -->
                    <StackPanel x:Name="SectionAbout" Visibility="Collapsed" Margin="0,0,0,8">
                        <TextBlock Text="关于" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="应用信息" FontSize="13" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,4,0,20"/>

                        <Border Style="{StaticResource SettingsSection}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource AccentBrush}"
                                               Text="&#xE946;" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="ToolBox" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="版本：" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock x:Name="txtVersion" Text="2.0.0" FontSize="13" FontFamily="{StaticResource FontMono}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="项目地址：" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Text="github.com/lin/ToolBox" FontSize="13" FontFamily="{StaticResource FontMono}" Foreground="{DynamicResource AccentBrush}"/>
                                </StackPanel>
                                <TextBlock Text="ToolBox 是一个集成截图、贴图、OCR、LLM 助手、待办管理等功能的桌面工具集。"
                                           FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ── Bottom Bar ── -->
        <Border Grid.Row="1" Height="56" Background="{DynamicResource BgOverlayBrush}"
                BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="32,0" VerticalAlignment="Center">
                <Button Content="重置为默认" Style="{StaticResource OutlineButton}" Click="BtnReset_Click"
                        Padding="20,8" FontSize="13" Margin="0,0,12,0"/>
                <Button Content="保存设置" Style="{StaticResource BtnPrimary}" Click="BtnSave_Click"
                        Padding="20,8" FontSize="13"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
