            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="32,0" VerticalAlignment="Center">
                <Button Content="{DynamicResource Lang_Reset}" Style="{StaticResource OutlineButton}" Click="BtnReset_Click"
                        Padding="20,8" FontSize="13" Margin="0,0,12,0"/>
                <Button Content="{DynamicResource Lang_Save}" Style="{StaticResource BtnPrimary}" Click="BtnSave_Click"
                        Padding="20,8" FontSize="13"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
