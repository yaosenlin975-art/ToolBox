<UserControl x:Class="ToolBox.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BgBrush}">
    <UserControl.Resources>
        <!-- ── Settings Nav Item (左侧 200px 导航) ── -->
        <Style x:Key="SettingsNavItem" TargetType="RadioButton">
            <Setter Property="FontFamily" Value="{StaticResource FontSans}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,1,0,0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bg" Background="Transparent"
                                BorderBrush="Transparent" BorderThickness="3,0,0,0"
                                CornerRadius="{StaticResource RadiusSm}" Padding="9,10,12,10">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="icon" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                           Foreground="{TemplateBinding Foreground}" Opacity="0.7"
                                           VerticalAlignment="Center" Margin="0,0,10,0"
                                           Text="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource BgHoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                <Setter TargetName="icon" Property="Opacity" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource AccentSoftBrush}"/>
                                <Setter TargetName="bg" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                <Setter TargetName="icon" Property="Opacity" Value="1"/>
                                <Setter TargetName="icon" Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Toggle Switch (40×22,自实现) ── -->
        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="track" Background="{DynamicResource BorderStrongBrush}"
                                CornerRadius="{StaticResource RadiusFull}">
                            <Grid>
                                <Border x:Name="thumbOff" Width="16" Height="16" CornerRadius="8"
                                        Background="{DynamicResource TextPrimaryBrush}"
                                        HorizontalAlignment="Left" VerticalAlignment="Center" Margin="3,0,0,0"/>
                                <Border x:Name="thumbOn" Width="16" Height="16" CornerRadius="8"
                                        Background="White"
                                        HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,3,0"
                                        Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="track" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="thumbOff" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="thumbOn" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Radio Card (卡片式单选,用于运行模式/主题) ── -->
        <Style x:Key="RadioCard" TargetType="RadioButton">
            <Setter Property="FontFamily" Value="{StaticResource FontSans}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="card" Background="Transparent"
                                BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1"
                                CornerRadius="{StaticResource RadiusMd}" Padding="16,8">
                            <StackPanel Orientation="Horizontal">
                                <Border x:Name="dot" Width="16" Height="16" CornerRadius="8"
                                        BorderBrush="{DynamicResource BorderStrongBrush}" BorderThickness="2"
                                        Background="Transparent" VerticalAlignment="Center" Margin="0,0,10,0">
                                    <Ellipse x:Name="dotFill" Width="6" Height="6" Fill="{DynamicResource AccentBrush}"
                                             Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="card" Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="card" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="card" Property="Background" Value="{DynamicResource AccentSoftBrush}"/>
                                <Setter TargetName="dot" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="dotFill" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Settings Section (卡片容器) ── -->
        <Style x:Key="SettingsSection" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="{StaticResource RadiusLg}"/>
            <Setter Property="Padding" Value="{StaticResource Space6}"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>

        <!-- ── Setting Row (左 info / 右 control) ── -->
        <Style x:Key="SettingRow" TargetType="Grid">
            <Setter Property="Margin" Value="0,12"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Settings Layout ── -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Settings Nav (200px) ── -->
            <Border Grid.Column="0" Background="{DynamicResource BgBrush}"
                    BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,0,1,0">
                <StackPanel Margin="0,24,0,0">
                    <TextBlock Text="{DynamicResource Lang_Settings}" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextTertiaryBrush}"
                               Margin="20,0,0,0" TextOptions.TextFormattingMode="Display">
                        <TextBlock.LayoutTransform><ScaleTransform ScaleX="1" ScaleY="1"/></TextBlock.LayoutTransform>
                    </TextBlock>
                    <StackPanel Margin="8,20,8,0">
                        <RadioButton x:Name="NavGeneral" GroupName="SettingsNav" IsChecked="True"
                                     Style="{StaticResource SettingsNavItem}" Tag="&#xE713;" Content="{DynamicResource Lang_General}" Checked="OnNavChecked"/>
                        <RadioButton x:Name="NavHotKey" GroupName="SettingsNav"
                                     Style="{StaticResource SettingsNavItem}" Tag="&#xE765;" Content="{DynamicResource Lang_Hotkey}" Checked="OnNavChecked"/>
                        <RadioButton x:Name="NavCapture" GroupName="SettingsNav"
                                     Style="{StaticResource SettingsNavItem}" Tag="&#xE722;" Content="{DynamicResource Lang_Capture}" Checked="OnNavChecked"/>
                        <RadioButton x:Name="NavActionChains" GroupName="SettingsNav"
                                     Style="{StaticResource SettingsNavItem}" Tag="&#xE9C5;" Content="截图动作链" Checked="OnNavChecked"/>
                        <RadioButton x:Name="NavLlm" GroupName="SettingsNav"
                                     Style="{StaticResource SettingsNavItem}" Tag="&#xE8BD;" Content="LLM" Checked="OnNavChecked"/>
                        <RadioButton x:Name="NavSchedule" GroupName="SettingsNav"
                                     Style="{StaticResource SettingsNavItem}" Tag="&#xE823;" Content="{DynamicResource Lang_Schedule}" Checked="OnNavChecked"/>
                        <RadioButton x:Name="NavClipboard" GroupName="SettingsNav"
                                     Style="{StaticResource SettingsNavItem}" Tag="&#xE77F;" Content="{DynamicResource Lang_Clipboard}" Checked="OnNavChecked"/>
                        <RadioButton x:Name="NavOcr" GroupName="SettingsNav"
                                     Style="{StaticResource SettingsNavItem}" Tag="&#xE7BC;" Content="OCR" Checked="OnNavChecked"/>
                        <RadioButton x:Name="NavLanguage" GroupName="SettingsNav"
                                     Style="{StaticResource SettingsNavItem}" Tag="&#xE774;" Content="{DynamicResource Lang_Language}" Checked="OnNavChecked"/>
                        <RadioButton x:Name="NavAbout" GroupName="SettingsNav"
                                     Style="{StaticResource SettingsNavItem}" Tag="&#xE946;" Content="{DynamicResource Lang_About}" Checked="OnNavChecked"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ── Settings Content ── -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="32,24,32,24">
                <StackPanel>
                    <StackPanel x:Name="SectionGeneral" Margin="0,0,0,8">
                        <TextBlock Text="{DynamicResource Lang_GeneralSettings}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="{DynamicResource Lang_GeneralHint}" FontSize="13" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,4,0,20"/>

                        <!-- Section: 应用模式 -->
                        <Border Style="{StaticResource SettingsSection}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource AccentBrush}"
                                               Text="&#xE7F4;" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{DynamicResource Lang_RunMode}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>

                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{DynamicResource Lang_RunMode}" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{DynamicResource Lang_RunModeHint}" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <RadioButton x:Name="rdoAppMode" GroupName="AppMode" Style="{StaticResource RadioCard}" IsChecked="True">
                                            <StackPanel>
                                                <TextBlock Text="{DynamicResource Lang_AppMode}" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{DynamicResource Lang_AppModeDesc}" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}"/>
                                            </StackPanel>
                                        </RadioButton>
                                        <RadioButton x:Name="rdoResidentMode" GroupName="AppMode" Style="{StaticResource RadioCard}">
                                            <StackPanel>
                                                <TextBlock Text="{DynamicResource Lang_ResidentMode}" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{DynamicResource Lang_ResidentModeDesc}" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}"/>
                                            </StackPanel>
                                        </RadioButton>
                                    </StackPanel>
                                </Grid>

                                <Border BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,1,0,0"/>

                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{DynamicResource Lang_AutoStartup}" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{DynamicResource Lang_AutoStartupHint}" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <CheckBox x:Name="chkAutoStartup" Grid.Column="1" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center"/>
                                </Grid>

                                <Border BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,1,0,0"/>

                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{DynamicResource Lang_Theme}" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{DynamicResource Lang_ThemeHint}" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <RadioButton x:Name="rdoThemeLight" GroupName="Theme" Style="{StaticResource RadioCard}" Checked="OnThemeChecked">
                                            <TextBlock Text="Light" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        </RadioButton>
                                        <RadioButton x:Name="rdoThemeDark" GroupName="Theme" Style="{StaticResource RadioCard}" Checked="OnThemeChecked">
                                            <TextBlock Text="Dark" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        </RadioButton>
                                        <RadioButton x:Name="rdoThemeSystem" GroupName="Theme" Style="{StaticResource RadioCard}" Checked="OnThemeChecked">
                                            <TextBlock Text="System" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        </RadioButton>
                                    </StackPanel>
                                </Grid>

                                <Border BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,1,0,0"/>

                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{DynamicResource Lang_MiniOpacity}" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{DynamicResource Lang_MiniOpacityHint}" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Width="280">
                                        <Slider x:Name="sldCompactOpacity" Style="{StaticResource ModernSlider}" Width="220"
                                                Minimum="30" Maximum="100" VerticalAlignment="Center"
                                                ValueChanged="SldCompactOpacity_ValueChanged"/>
                                        <TextBlock x:Name="txtCompactOpacityValue" Text="50" FontSize="11" FontFamily="{StaticResource FontMono}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" MinWidth="36" TextAlignment="Right" Margin="12,0,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- ── Section: 截图动作链 ── -->
                    <StackPanel x:Name="SectionActionChains" Visibility="Collapsed" Margin="0,0,0,8">
                        <TextBlock Text="截图动作链" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="配置截图完成后自动执行的动作序列，例如&quot;OCR → 复制&quot;直接提字到剪贴板" FontSize="13" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,4,0,20"/>

                        <Border Style="{StaticResource SettingsSection}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource AccentBrush}"
                                               Text="&#xE9C5;" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="动作链管理" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>

                                <!-- 当前默认链 -->
                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="当前默认动作链" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="截图后自动执行此链" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <ComboBox x:Name="cmbDefaultChain" Grid.Column="1" Width="240" HorizontalAlignment="Left" SelectionChanged="CmbDefaultChain_SelectionChanged"/>
                                </Grid>

                                <Border BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,1,0,0"/>

                                <!-- 链列表 -->
                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="已有动作链" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock x:Name="txtChainCount" Text="0 条链" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}"/>
                                    </StackPanel>
                                    <Button x:Name="btnAddChain" Content="+ 新建链" Style="{StaticResource BtnPrimary}" Padding="12,4" FontSize="12" Click="BtnAddChain_Click"/>
                                </Grid>

                                <!-- 动作链卡片列表 -->
                                <Border BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,1,0,0"/>
                                <StackPanel x:Name="ActionChainCards" Margin="0,12,0,0"/>

                                <!-- 配置 -->
                                <Border BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,1,0,0" Margin="0,16,0,0"/>
                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="遇错继续执行" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="节点出错时不停止，继续执行下一个节点" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <CheckBox x:Name="chkContinueOnError" Grid.Column="1" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center" Checked="ChkContinueOnError_CheckedChanged" Unchecked="ChkContinueOnError_CheckedChanged"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- ── Section: 快捷键 ── -->
                    <StackPanel x:Name="SectionHotKey" Visibility="Collapsed" Margin="0,0,0,8">
                        <TextBlock Text="{DynamicResource Lang_Hotkey}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="{DynamicResource Lang_HotkeyHint2}" FontSize="13" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,4,0,20"/>

                        <Border Style="{StaticResource SettingsSection}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource AccentBrush}"
                                               Text="&#xE765;" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{DynamicResource Lang_GlobalHotkey}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>

                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{DynamicResource Lang_EnableHotkey}" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{DynamicResource Lang_EnableHotkeyHint}" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <CheckBox x:Name="chkHotKeyEnable" Grid.Column="1" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center"/>
                                </Grid>

                                <Border BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,1,0,0"/>

                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{DynamicResource Lang_Capture}" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{DynamicResource Lang_HotkeyInputHint}" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <TextBox x:Name="txtHotKey1" Grid.Column="1" Width="160" IsReadOnly="True"
                                             Text="Ctrl+1" FontSize="13" FontFamily="{StaticResource FontMono}"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             Background="{DynamicResource BgSunkenBrush}"
                                             BorderBrush="{DynamicResource BorderDefaultBrush}"
                                             CaretBrush="{DynamicResource TextPrimaryBrush}"
                                             PreviewKeyDown="HotKey_PreviewKeyDown"
                                             GotFocus="HotKey_GotFocus"
                                             LostFocus="HotKey_LostFocus"
                                             ToolTip="{DynamicResource Lang_HotkeyInputHint}"/>
                                </Grid>

                                <Border BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,1,0,0"/>

                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{DynamicResource Lang_ShowHideHotkey}" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{DynamicResource Lang_HotkeyInputHint}" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <TextBox x:Name="txtHotKey2" Grid.Column="1" Width="160" IsReadOnly="True"
                                             Text="Ctrl+2" FontSize="13" FontFamily="{StaticResource FontMono}"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             Background="{DynamicResource BgSunkenBrush}"
                                             BorderBrush="{DynamicResource BorderDefaultBrush}"
                                             CaretBrush="{DynamicResource TextPrimaryBrush}"
                                             PreviewKeyDown="HotKey_PreviewKeyDown"
                                             GotFocus="HotKey_GotFocus"
                                             LostFocus="HotKey_LostFocus"
                                             ToolTip="{DynamicResource Lang_HotkeyInputHint}"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- ── Section: 截图 ── -->
                    <StackPanel x:Name="SectionCapture" Visibility="Collapsed" Margin="0,0,0,8">
                        <TextBlock Text="{DynamicResource Lang_CaptureSettings}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="{DynamicResource Lang_CaptureHint}" FontSize="13" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,4,0,20"/>

                        <Border Style="{StaticResource SettingsSection}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource AccentBrush}"
                                               Text="&#xE722;" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{DynamicResource Lang_Capture}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>

                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{DynamicResource Lang_Transparency}" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{DynamicResource Lang_TransparencyHint}" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Width="280">
                                        <Slider x:Name="sldAreaTransparent" Style="{StaticResource ModernSlider}" Width="220"
                                                Minimum="0" Maximum="255" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="txtAreaTransparentValue" Text="80" FontSize="11" FontFamily="{StaticResource FontMono}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" MinWidth="36" TextAlignment="Right" Margin="12,0,0,0"/>
                                    </StackPanel>
                                </Grid>

                                <Border BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,1,0,0"/>

                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{DynamicResource Lang_LineStyle}" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{DynamicResource Lang_LineStyleHint}" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <RadioButton x:Name="rdoLineSolid" GroupName="LineStyle" Content="{DynamicResource Lang_LineSolid}" Style="{StaticResource ModernRadioButton}" Margin="0,0,16,0"/>
                                        <RadioButton x:Name="rdoLineDotted" GroupName="LineStyle" Content="{DynamicResource Lang_LineDotted}" Style="{StaticResource ModernRadioButton}"/>
                                    </StackPanel>
                                </Grid>

                                <Border BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,1,0,0"/>

                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="截图历史最大时效" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="超过时效的截图将自动从历史中清理" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
