<Window x:Class="ToolBox.Views.PreviewCard.PreviewCardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="200" Height="150"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize">
    <Window.Resources>
        <!-- 入场动画 -->
        <Storyboard x:Key="SlideInStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="80" To="0" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.2"/>
        </Storyboard>
        <!-- 离场动画 -->
        <Storyboard x:Key="SlideOutStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.3"
                             Completed="OnSlideOutCompleted"/>
        </Storyboard>
        <!-- 悬停放大动画 -->
        <Storyboard x:Key="HoverInStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                             To="1.05" Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                             To="1.05" Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="HoverOutStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                             To="1.0" Duration="0:0:0.15"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                             To="1.0" Duration="0:0:0.15"/>
        </Storyboard>
    </Window.Resources>
    <Window.RenderTransform>
        <TransformGroup>
            <TranslateTransform x:Name="SlideTransform" Y="80"/>
            <ScaleTransform x:Name="ScaleTransform" CenterX="100" CenterY="75"/>
        </TransformGroup>
    </Window.RenderTransform>

    <Border Width="200" Height="150"
            CornerRadius="14"
            Background="{DynamicResource BgElevatedBrush}"
            BorderBrush="{DynamicResource BorderDefaultBrush}"
            BorderThickness="1"
            Opacity="0.95"
            x:Name="CardBorder">
        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="发送到 AI" Click="OnSendToAiClick"/>
                <MenuItem Header="保存为文件" Click="OnSaveClick"/>
                <Separator/>
                <MenuItem Header="丢弃" Click="OnDiscardClick"/>
            </ContextMenu>
        </Border.ContextMenu>
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="8" Opacity="0.10" Color="#000000"/>
        </Border.Effect>
        <Border.RenderTransform>
            <ScaleTransform CenterX="100" CenterY="75"/>
        </Border.RenderTransform>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 缩略图区域 -->
            <Border Grid.Row="0" Margin="8,8,8,4"
                    CornerRadius="8"
                    ClipToBounds="True">
                <!-- 棋盘格背景表示透明区域 -->
                <Border.Background>
                    <DrawingBrush TileMode="Tile" Viewport="0,0,16,16" ViewportUnits="Absolute">
                        <DrawingBrush.Drawing>
                            <DrawingGroup>
                                <GeometryDrawing Brush="{DynamicResource BgSunkenBrush}">
                                    <GeometryDrawing.Geometry>
                                        <RectangleGeometry Rect="0,0,16,16"/>
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                                <GeometryDrawing Brush="#10000000">
                                    <GeometryDrawing.Geometry>
                                        <GeometryGroup>
                                            <RectangleGeometry Rect="0,0,8,8"/>
                                            <RectangleGeometry Rect="8,8,8,8"/>
                                        </GeometryGroup>
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                            </DrawingGroup>
                        </DrawingBrush.Drawing>
                    </DrawingBrush>
                </Border.Background>
                <Image x:Name="ThumbnailImage"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       MouseLeftButtonDown="OnThumbnailMouseDown"
                       Cursor="SizeAll"/>
            </Border>

            <!-- 操作按钮行 -->
            <StackPanel Grid.Row="1" Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,8">
                <Button x:Name="BtnEdit" Content="&#xE70F;"
                        Style="{StaticResource IconButton}"
                        Width="28" Height="28" FontSize="14"
                        Margin="0,0,16,0"
                        ToolTip="编辑"
                        Click="OnEditClick"/>
                <Button x:Name="BtnPin" Content="&#xE718;"
                        Style="{StaticResource IconButton}"
                        Width="28" Height="28" FontSize="14"
                        Margin="0,0,16,0"
                        ToolTip="贴图置顶"
                        Click="OnPinClick"/>
                <Button x:Name="BtnCopy" Content="&#xE8C8;"
                        Style="{StaticResource IconButton}"
                        Width="28" Height="28" FontSize="14"
                        ToolTip="复制到剪贴板"
                        Click="OnCopyClick"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
