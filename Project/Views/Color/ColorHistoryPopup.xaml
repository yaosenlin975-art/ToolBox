<Window x:Class="ToolBox.Views.ColorPicker.ColorHistoryPopup"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   Title="ColorHistory" Height="116" Width="220"
                   WindowStyle="None"
                   AllowsTransparency="True"
                   ResizeMode="NoResize"
                   ShowInTaskbar="False"
                   Background="Transparent"
                   Topmost="True">
    <Border Background="{DynamicResource BgElevatedBrush}"
            BorderBrush="{DynamicResource BorderDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12,10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="4" Opacity="0.16" Color="#000000"/>
        </Border.Effect>
        <StackPanel>
            <TextBlock Text="最近取色"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       Margin="0,0,0,8"/>
            <UniformGrid x:Name="HistoryGrid" Columns="5" Rows="2"/>
        </StackPanel>
    </Border>
</Window>
