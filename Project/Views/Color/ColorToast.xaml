<Window x:Class="ToolBox.Views.ColorPicker.ColorToast"
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           Title="ColorToast" Height="44" Width="220"
           WindowStyle="None"
           AllowsTransparency="True"
           ResizeMode="NoResize"
           ShowInTaskbar="False"
           Background="Transparent"
           Topmost="True">
    <Border Background="{DynamicResource BgElevatedBrush}"
            BorderBrush="{DynamicResource BorderDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12,8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="4" Opacity="0.16" Color="#000000"/>
        </Border.Effect>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <Ellipse x:Name="ColorDot" Width="18" Height="18" Margin="0,0,10,0"
                     Stroke="{DynamicResource BorderDefaultBrush}" StrokeThickness="1"/>
            <TextBlock x:Name="MessageText" FontSize="13" FontWeight="Medium"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center"/>
        </StackPanel>
    </Border>
</Window>
