<!-- File: OcrTextPopup.xaml
     贴图选字 OCR 浮层(280×200)。显示识别文字 + 复制/翻译按钮(AC2.2)。 -->
<Window x:Class="ToolBox.Views.Ocr.OcrTextPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Topmost="True"
        Width="280" Height="200"
        KeyDown="OnKeyDown">
    <Border Background="{DynamicResource BgSecondaryBrush}"
            BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1" CornerRadius="6"
            MouseLeftButtonDown="HeaderDrag">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBox x:Name="TextBox" Grid.Row="0" Margin="8,8,8,4"
                     IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                     Background="Transparent" BorderThickness="0"
                     FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"
                     CaretBrush="{DynamicResource AccentBrush}"/>

            <Border Grid.Row="1" Grid.RowSpan="2" x:Name="LoadingLayer" Background="{DynamicResource BgSecondaryBrush}"
                    Visibility="Collapsed" CornerRadius="6">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="识别中..." FontSize="12" HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <ProgressBar Width="200" Height="3" Margin="0,8,0,0" IsIndeterminate="True"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,8,8">
                <Button Style="{StaticResource BtnDefault}" Margin="0,0,6,0" Click="CopyClick" Content="复制"/>
                <Button Style="{StaticResource BtnDefault}" Margin="0,0,6,0" Click="TranslateClick" Content="翻译"/>
                <Button Style="{StaticResource BtnDefault}" Click="CloseClick" Content="关闭"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
