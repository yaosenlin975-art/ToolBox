<!-- File: OcrResultOverlay.xaml
     OCR 识别结果窗口(独立窗口)。左侧文本列表(低置信度黄色标记)，右侧缩略图+边界框高亮，底部复制/翻译/发送到AI/关闭。
     AC1.3/AC1.4/AC1.5/AC1.6 的承载界面。 -->
<Window x:Class="ToolBox.Views.Ocr.OcrResultOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        Width="780" Height="520"
        MinWidth="640" MinHeight="420"
        WindowStartupLocation="CenterScreen"
        KeyDown="OnKeyDown">
    <Border Background="{DynamicResource BgSecondaryBrush}"
            BorderBrush="{DynamicResource BorderDefaultBrush}"
            BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题栏(可拖动) -->
            <Border Grid.Row="0" Padding="16,12" MouseLeftButtonDown="HeaderDrag"
                    BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="OCR 识别结果" FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="EngineBadge" Margin="12,0,0,0" FontSize="11"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                            Style="{StaticResource IconButton}" Click="CloseClick" Content="✕"/>
                </Grid>
            </Border>

            <!-- 内容区:左文本 + 右缩略图 -->
            <Grid Grid.Row="1" Margin="16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="360"/>
                </Grid.ColumnDefinitions>

                <!-- 左:文本列表 -->
                <DockPanel Grid.Column="0">
                    <TextBlock DockPanel.Dock="Top" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,8"
                               Text="识别文本(点击行可在右侧高亮对应区域)"/>
                    <Border Background="{DynamicResource BgTertiaryBrush}"
                            BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4">
                        <ListBox x:Name="LineList" Background="Transparent" BorderThickness="0"
                                 ItemContainerStyle="{StaticResource ModernListBoxItem}"
                                 SelectionChanged="LineSelected"/>
                    </Border>
                </DockPanel>

                <!-- 右:缩略图 + 边界框 -->
                <StackPanel Grid.Column="1" Margin="16,0,0,0">
                    <TextBlock FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,8"
                               Text="缩略图(黄色框为当前行)"/>
                    <Border Background="{DynamicResource BgTertiaryBrush}"
                            BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4"
                            Width="340" Height="320">
                        <Grid x:Name="ThumbHost" ClipToBounds="True">
                            <Image x:Name="ThumbImage" Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                            <Canvas x:Name="BoxCanvas" IsHitTestVisible="False"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- 加载层(覆盖内容区) -->
            <Border x:Name="LoadingPanel" Grid.Row="1" Background="{DynamicResource BgSecondaryBrush}"
                    Visibility="Collapsed">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock x:Name="LoadingText" Text="识别中..." FontSize="14"
                               Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                    <ProgressBar x:Name="LoadingProgress" Width="260" Height="4" Margin="0,14,0,0"
                                 IsIndeterminate="True"/>
                    <TextBlock x:Name="DownloadStatus" FontSize="11" Margin="0,10,0,0"
                               Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- 底部按钮栏 -->
            <Border Grid.Row="2" Padding="16,12"
                    BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,1,0,0">
                <Grid>
                    <TextBlock x:Name="StatusTip" VerticalAlignment="Center" FontSize="11"
                               Foreground="{DynamicResource TextTertiaryBrush}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource BtnDefault}" Margin="0,0,8,0"
                                Click="CopyAllClick" Content="复制全部"/>
                        <Button Style="{StaticResource BtnDefault}" Margin="0,0,8,0"
                                Click="TranslateClick" Content="翻译选中"/>
                        <Button Style="{StaticResource BtnPrimary}" Margin="0,0,8,0"
                                Click="SendToAiClick" Content="发送到 AI"/>
                        <Button Style="{StaticResource BtnDefault}" Click="CloseClick" Content="关闭"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
