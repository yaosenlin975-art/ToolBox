<Window x:Class="ToolBox.Views.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ToolBox" Height="360" Width="480"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True">
    <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="20"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" Opacity="0.08" ShadowDepth="8" Color="Black"/>
        </Border.Effect>
        <Grid>
            <!-- 装饰圆 -->
            <Ellipse Width="220" Height="220" Fill="{DynamicResource AccentBrush}"
                     Opacity="0.08" HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,-80,-80,0"/>
            <Ellipse Width="180" Height="180" Fill="{DynamicResource AccentBrush}"
                     Opacity="0.05" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                     Margin="-50,0,0,-50"/>

            <!-- 内容 -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <!-- Logo -->
                <Border Width="56" Height="56" CornerRadius="12"
                        Background="{DynamicResource AccentBrush}" Margin="0,0,0,16">
                    <TextBlock Text="T" Foreground="{DynamicResource TextInvertedBrush}"
                               FontSize="32" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <TextBlock HorizontalAlignment="Center" FontSize="24" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}">
                    <Run Text="Tool"/>
                    <Run Text="Box" Foreground="{DynamicResource AccentBrush}"/>
                </TextBlock>
                <TextBlock Text="Screenshots · Pins · AI Assistant" FontSize="13"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,6,0,0"/>

                <!-- Loading Bar -->
                <Grid Width="220" Margin="0,32,0,8">
                    <Border Height="4" CornerRadius="2"
                            Background="{DynamicResource BgSunkenBrush}"/>
                    <Border x:Name="LoadingFill" Height="4" CornerRadius="2"
                            HorizontalAlignment="Left" Width="0"
                            Background="{DynamicResource AccentBrush}"/>
                </Grid>

                <!-- Status -->
                <TextBlock x:Name="StatusText" Text="正在初始化..." FontSize="11"
                           FontFamily="{StaticResource FontMono}"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           HorizontalAlignment="Center" Margin="0,4,0,16"/>

                <!-- Button Row -->
                <StackPanel x:Name="ButtonRow" Orientation="Horizontal" HorizontalAlignment="Center"
                            Visibility="Collapsed">
                    <Button x:Name="RetryBtn" Content="重试" Padding="16,6" Margin="0,0,10,0"
                            Style="{StaticResource BtnPrimary}" FontSize="12"
                            Click="RetryBtn_Click" Visibility="Collapsed"/>
                    <Button x:Name="CloseBtn" Content="关闭" Padding="16,6"
                            Style="{StaticResource OutlineButton}" FontSize="12"
                            Click="CloseBtn_Click"/>
                </StackPanel>
            </StackPanel>

            <!-- 版本号 -->
            <TextBlock Text="v2.0.0" FontSize="11" FontFamily="{StaticResource FontMono}"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       HorizontalAlignment="Right" VerticalAlignment="Bottom"
                       Margin="0,0,20,16" Opacity="0.6"/>
        </Grid>
    </Border>
</Window>
