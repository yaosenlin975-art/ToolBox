<Window x:Class="ToolBox.Views.InputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="输入" Width="360" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="NoResize" ShowInTaskbar="False"
        Background="Transparent">
    <Border Background="{DynamicResource BgElevatedBrush}"
            BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1"
            CornerRadius="{StaticResource RadiusMd}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="8" Opacity="0.2" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Background="{DynamicResource BgElevatedBrush}"
                  MouseLeftButtonDown="OnTitleBarMouseDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="TitleDisplay" Text="输入" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" Margin="14,0,0,0"/>
                <Button Grid.Column="1" Width="28" Height="28" Style="{StaticResource IconButton}"
                        Click="OnClose" Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                        Margin="0,0,6,0"/>
            </Grid>
            <Grid Grid.Row="1" Margin="20,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" x:Name="Prompt" FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBox Grid.Row="1" x:Name="Input" Margin="0,8,0,0" Height="28" FontSize="13"
                         Background="{DynamicResource BgSunkenBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource BorderDefaultBrush}"
                         CaretBrush="{DynamicResource TextPrimaryBrush}"
                         KeyDown="Input_KeyDown"/>
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                    <Button Content="取消" Width="72" Height="28" Margin="0,0,8,0"
                            Style="{StaticResource OutlineButton}" Click="Cancel_Click"/>
                    <Button Content="确定" Width="72" Height="28"
                            Style="{StaticResource BtnPrimary}" Click="OK_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
