<Window x:Class="ToolBox.Views.InputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="输入" Width="360" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="NoResize" ShowInTaskbar="False"
        Background="Transparent">
    <Border Background="{DynamicResource BgElevatedBrush}"
            BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1"
            CornerRadius="{StaticResource RadiusMd}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="8" Opacity="0.2" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Background="{DynamicResource BgElevatedBrush}"
                  MouseLeftButtonDown="OnTitleBarMouseDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="TitleDisplay" Text="输入" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" Margin="14,0,0,0"/>
                <Button Grid.Column="1" Width="28" Height="28" Style="{StaticResource IconButton}"
                        Click="OnClose" Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                        Margin="0,0,6,0"/>
            </Grid>
            <Grid Grid.Row="1" Margin="20,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" x:Name="Prompt" FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBox Grid.Row="1" x:Name="Input" Margin="0,8,0,0" Height="28" FontSize="13"
                         Background="{DynamicResource BgSunkenBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource BorderDefaultBrush}"
                         CaretBrush="{DynamicResource TextPrimaryBrush}"
                         KeyDown="Input_KeyDown" TextChanged="Input_TextChanged"/>
                <!-- Date suggestion popup -->
                <Border x:Name="DateSuggestionPanel" Grid.Row="2" Visibility="Collapsed"
                        Background="{DynamicResource BgSecondaryBrush}" CornerRadius="6"
                        Padding="8,4" Margin="0,4,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📅 " VerticalAlignment="Center"/>
                        <TextBlock x:Name="txtDateSuggestion" FontSize="11"
                                   Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                        <Button x:Name="BtnClearDate" Content="✕" Width="20" Height="20" Margin="8,0,0,0"
                                Style="{StaticResource IconButton}" FontSize="10"
                                Click="BtnClearDate_Click"/>
                    </StackPanel>
                </Border>
                <!-- 分类 + 优先级 + 截止日期 -->
                <StackPanel x:Name="TodoExtraPanel" Grid.Row="3" Visibility="Collapsed" Margin="0,10,0,0">
                    <TextBlock Text="分类" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBox x:Name="CategoryInput" Grid.Row="0" FontSize="12" Padding="6,4"
                                 Background="{DynamicResource BgSunkenBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                                 BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1"
                                 TextChanged="CategoryInput_TextChanged"/>
                        <ListBox x:Name="CategorySuggestions" Grid.Row="1" MaxHeight="80" Margin="0,2,0,0"
                                 Visibility="Collapsed" FontSize="11" Background="{DynamicResource BgElevatedBrush}"
                                 BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1"
                                 SelectionChanged="CategorySuggestion_Selected"/>
                    </Grid>
                    <TextBlock Text="紧急程度" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <RadioButton x:Name="PriLow" Content="普通" IsChecked="True" Margin="0,0,8,0"
                                     Style="{StaticResource PriOptionStyle}"/>
                        <RadioButton x:Name="PriMid" Content="重要" Margin="0,0,8,0"
                                     Style="{StaticResource PriOptionStyle}"/>
                        <RadioButton x:Name="PriHigh" Content="紧急"
                                     Style="{StaticResource PriOptionStyle}"/>
                    </StackPanel>
                    <TextBlock Text="截止日期" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <DatePicker x:Name="DueDatePicker" FontSize="12"
                                Foreground="{DynamicResource TextPrimaryBrush}"/>
                </StackPanel>
                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                    <Button Content="取消" Width="72" Margin="0,0,8,0"
                            Style="{StaticResource OutlineButton}" Click="Cancel_Click"/>
                    <Button Content="确定" Width="72"
                            Style="{StaticResource BtnPrimary}" Click="OK_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
