<Window x:Class="ToolBox.Views.HotkeyInputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Set Hotkey" Height="200" Width="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgSecondaryBrush}"
        SourceInitialized="Window_SourceInitialized">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Press a key combination" HorizontalAlignment="Center"
                       FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,16"/>
            <TextBlock x:Name="lblKey" Text="Waiting..." HorizontalAlignment="Center"
                       FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"
                       FontFamily="Consolas, Segoe UI" Margin="0,0,0,12"/>
            <TextBlock Text="Press ESC to cancel" HorizontalAlignment="Center"
                       FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="24,0,24,20">
            <Button Content="Cancel" Click="BtnCancel_Click" Width="100" Height="34"
                    Style="{StaticResource BtnDefault}" Margin="0,0,8,0"/>
            <Button Content="OK" Click="BtnOk_Click" Width="100" Height="34"
                    Style="{StaticResource BtnPrimary}"/>
        </StackPanel>
    </Grid>
</Window>
