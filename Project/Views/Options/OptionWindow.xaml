<Window x:Class="ToolBox.Views.OptionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ToolBox Options" Height="600" Width="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgPrimaryBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="0"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{StaticResource BgSecondaryBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="24,0,24,0">
            <TabControl x:Name="tabMain" Style="{StaticResource ModernTabControl}">
                <TabItem Header="General" Style="{StaticResource ModernTabItem}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20">
                        <StackPanel>
                            <TextBlock Text="GENERAL" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,12"/>
                            <GroupBox Header="Startup" Style="{StaticResource ModernGroupBox}">
                                <StackPanel>
                                    <RadioButton x:Name="rdoAppMode" Content="Application Mode" Style="{StaticResource ModernRadioButton}" Margin="0,0,0,8"/>
                                    <RadioButton x:Name="rdoResidentMode" Content="Resident Mode" Style="{StaticResource ModernRadioButton}"/>
                                </StackPanel>
                            </GroupBox>
                            <CheckBox x:Name="chkShowMainWindow" Content="Show main window on startup" Style="{StaticResource ModernCheckBox}" Margin="0,0,0,10"/>
                            <CheckBox x:Name="chkSplash" Content="Show splash screen" Style="{StaticResource ModernCheckBox}" Margin="0,0,0,10"/>
                            <CheckBox x:Name="chkAutoStartup" Content="Auto start on boot" Style="{StaticResource ModernCheckBox}" Margin="0,0,0,10"/>
                            <CheckBox x:Name="chkTopMost" Content="Pin windows on top" Style="{StaticResource ModernCheckBox}"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
                <TabItem Header="Hotkey" Style="{StaticResource ModernTabItem}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20">
                        <StackPanel>
                            <TextBlock Text="HOTKEY" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,12"/>
                            <CheckBox x:Name="chkHotKeyEnable" Content="Enable global hotkeys" Style="{StaticResource ModernCheckBox}" Margin="0,0,0,16"/>
                            <GroupBox Header="Hotkey Settings" Style="{StaticResource ModernGroupBox}">
                                <StackPanel>
                                    <Border Background="{StaticResource BgTertiaryBrush}" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Capture Hotkey" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Width="120"/>
                                            <Border Background="{StaticResource BgSecondaryBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="12,4" MinWidth="100">
                                                <TextBlock x:Name="txtHotKey1" Text="Ctrl + 1" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Consolas, Segoe UI" HorizontalAlignment="Center"/>
                                            </Border>
                                            <Button Content="Change" Click="BtnChangeHotKey1_Click" Style="{StaticResource BtnDefault}" FontSize="12" Margin="12,0,0,0" Padding="12,4" Foreground="{StaticResource AccentBrush}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="{StaticResource BgTertiaryBrush}" CornerRadius="6" Padding="12">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Show/Hide All" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Width="120"/>
                                            <Border Background="{StaticResource BgSecondaryBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="12,4" MinWidth="100">
                                                <TextBlock x:Name="txtHotKey2" Text="Ctrl + 2" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Consolas, Segoe UI" HorizontalAlignment="Center"/>
                                            </Border>
                                            <Button Content="Change" Click="BtnChangeHotKey2_Click" Style="{StaticResource BtnDefault}" FontSize="12" Margin="12,0,0,0" Padding="12,4" Foreground="{StaticResource AccentBrush}"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </GroupBox>
                            <TextBlock Text="Click Change then press a new key combination." FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
                <TabItem Header="Capture" Style="{StaticResource ModernTabItem}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20">
                        <StackPanel>
                            <TextBlock Text="CAPTURE" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,12"/>
                            <GroupBox Header="Selection Line" Style="{StaticResource ModernGroupBox}">
                                <StackPanel>
                                    <RadioButton x:Name="rdoLineSolid" Content="Solid" Style="{StaticResource ModernRadioButton}" Margin="0,0,0,8"/>
                                    <RadioButton x:Name="rdoLineDotted" Content="Dashed" Style="{StaticResource ModernRadioButton}"/>
                                </StackPanel>
                            </GroupBox>
                            <GroupBox Header="Colors" Style="{StaticResource ModernGroupBox}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <TextBlock Text="Line Color" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Width="100"/>
                                        <Border x:Name="rectLineColor" Width="28" Height="28" CornerRadius="6" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1.5" Cursor="Hand"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <TextBlock Text="Area BG" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Width="100"/>
                                        <Border x:Name="rectBackColor" Width="28" Height="28" CornerRadius="6" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1.5" Cursor="Hand"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Transparency" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Width="100"/>
                                        <Slider x:Name="sliderTransparency" Width="150" Style="{StaticResource ModernSlider}" Minimum="0" Maximum="255" Value="80"/>
                                    </StackPanel>
                                </StackPanel>
                            </GroupBox>
                            <CheckBox x:Name="chkCursor" Content="Custom cursor" Style="{StaticResource ModernCheckBox}" Margin="0,0,0,10"/>
                            <CheckBox x:Name="chkFullscreenCursor" Content="Fullscreen crosshair" Style="{StaticResource ModernCheckBox}" Margin="0,0,0,10"/>
                            <CheckBox x:Name="chkMagnifier" Content="Pixel magnifier" Style="{StaticResource ModernCheckBox}"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
                <TabItem Header="Scrap" Style="{StaticResource ModernTabItem}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20">
                        <StackPanel>
                            <TextBlock Text="SCRAP" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,12"/>
                            <CheckBox x:Name="chkScrapImageDrag" Content="Allow drag image to scrap" Style="{StaticResource ModernCheckBox}" Margin="0,0,0,16"/>
                            <GroupBox Header="Opacity" Style="{StaticResource ModernGroupBox}">
                                <StackPanel>
                                    <CheckBox x:Name="chkInactiveAlpha" Content="Dim when inactive" Style="{StaticResource ModernCheckBox}" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal" Margin="20,0,0,12">
                                        <TextBlock Text="Value:" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                        <TextBox x:Name="txtInactiveAlpha" Width="60" Style="{StaticResource InputField}" Margin="8,0" TextAlignment="Center"/>
                                    </StackPanel>
                                    <CheckBox x:Name="chkMouseOverAlpha" Content="Adjust on hover" Style="{StaticResource ModernCheckBox}" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                                        <TextBlock Text="Value:" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                        <TextBox x:Name="txtMouseOverAlpha" Width="60" Style="{StaticResource InputField}" Margin="8,0" TextAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </GroupBox>
                            <GroupBox Header="Dust Box" Style="{StaticResource ModernGroupBox}">
                                <StackPanel>
                                    <CheckBox x:Name="chkDustBox" Content="Enable dust box" Style="{StaticResource ModernCheckBox}" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Capacity:" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                        <TextBox x:Name="txtDustBoxCapacity" Width="60" Style="{StaticResource InputField}" Margin="8,0" Text="5" TextAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
                <TabItem Header="Menu" Style="{StaticResource ModernTabItem}">
                    <Grid Margin="24,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ListBox x:Name="lstScrapMenuList" Grid.Column="0" Style="{StaticResource ModernListBox}"/>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <Button Content="Add" Click="BtnAddMenuItem_Click" Style="{StaticResource BtnDefault}" Width="80" Margin="0,0,0,8"/>
                            <Button Content="Remove" Click="BtnRemoveMenuItem_Click" Style="{StaticResource BtnDefault}" Width="80"/>
                        </StackPanel>
                    </Grid>
                </TabItem>
                <TabItem Header="Style" Style="{StaticResource ModernTabItem}">
                    <Grid Margin="24,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ListBox x:Name="lstStyles" Grid.Column="0" Style="{StaticResource ModernListBox}" DisplayMemberPath="StyleName"/>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <Button Content="Add" Click="BtnAddStyle_Click" Style="{StaticResource BtnDefault}" Width="80" Margin="0,0,0,8"/>
                            <Button Content="Edit" Click="BtnEditStyle_Click" Style="{StaticResource BtnDefault}" Width="80" Margin="0,0,0,8"/>
                            <Button Content="Delete" Click="BtnRemoveStyle_Click" Style="{StaticResource BtnDefault}" Width="80" Foreground="{StaticResource DangerBrush}"/>
                        </StackPanel>
                    </Grid>
                </TabItem>
                <TabItem Header="Misc" Style="{StaticResource ModernTabItem}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20">
                        <StackPanel>
                            <TextBlock Text="MISC" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,12"/>
                            <CheckBox x:Name="chkBackgroundTransparent" Content="Background transparent" Style="{StaticResource ModernCheckBox}" Margin="0,0,0,16"/>
                            <GroupBox Header="Fullscreen Cursor" Style="{StaticResource ModernGroupBox}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <TextBlock Text="Color:" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Width="80"/>
                                        <Border x:Name="rectCursorColor" Width="28" Height="28" CornerRadius="6" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1.5" Cursor="Hand"/>
                                    </StackPanel>
                                    <RadioButton x:Name="rdoCursorSolid" Content="Solid" Style="{StaticResource ModernRadioButton}" Margin="0,0,0,8"/>
                                    <RadioButton x:Name="rdoCursorHollow" Content="Hollow" Style="{StaticResource ModernRadioButton}"/>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
                                            <TabItem Header="LLM" Style="{StaticResource ModernTabItem}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20">
                        <StackPanel>
                            <TextBlock Text="LLM ASSISTANT" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,12"/>
                            <GroupBox Header="Provider" Style="{StaticResource ModernGroupBox}">
                                <StackPanel>
                                    <TextBlock Text="Provider:" FontSize="13" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="cmbProvider" Width="200" Margin="0,0,0,8"/>
                                    <TextBlock Text="Model:" FontSize="13" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="cmbModel" Width="200" Margin="0,0,0,8"/>
                                    <TextBlock Text="API Key:" FontSize="13" Margin="0,0,0,4"/>
                                    <PasswordBox x:Name="txtApiKey" Width="300" Margin="0,0,0,8"/>
                                    <TextBlock Text="Base URL:" FontSize="13" Margin="0,0,0,4"/>
                                    <TextBox x:Name="txtBaseUrl" Width="300" Margin="0,0,0,8"/>
                                    <Button Content="Test Connection" Width="120" Style="{StaticResource BtnDefault}" Click="TestConnection_Click"/>
                                </StackPanel>
                            </GroupBox>
                            <GroupBox Header="File Whitelist" Style="{StaticResource ModernGroupBox}" Margin="0,12,0,0">
                                <StackPanel>
                                    <ListBox x:Name="WhitelistBox" Height="100" Margin="0,0,0,6"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBox x:Name="WhitelistInput" Width="250" Margin="0,0,6,0"/>
                                        <Button Content="Add" Width="60" Style="{StaticResource BtnDefault}" Click="WhitelistAdd_Click"/>
                                        <Button Content="Remove" Width="70" Style="{StaticResource BtnDefault}" Click="WhitelistRemove_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
<TabItem Header="Language" Style="{StaticResource ModernTabItem}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20">
                        <StackPanel>
                            <TextBlock Text="LANGUAGE" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,12"/>
                            <GroupBox Header="Language" Style="{StaticResource ModernGroupBox}">
                                <StackPanel>
                                    <RadioButton x:Name="rdoLangZh" Content="中文 (Chinese)" Style="{StaticResource ModernRadioButton}" Margin="0,0,0,8"/>
                                    <RadioButton x:Name="rdoLangEn" Content="English" Style="{StaticResource ModernRadioButton}"/>
                                </StackPanel>
                            </GroupBox>
                            <TextBlock Text="Restart required after changing language" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>            </TabControl>
        </Border>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,24,20">
            <Button Content="Cancel" Click="BtnCancel_Click" Width="100" Height="34" Style="{StaticResource BtnDefault}" Margin="0,0,8,0"/>
            <Button Content="Save" Click="BtnSave_Click" Width="100" Height="34" Style="{StaticResource BtnPrimary}"/>
        </StackPanel>
    </Grid>
</Window>


