<Window x:Class="ToolBox.Views.Todo.TodoDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="任务详情" Width="320" Height="480"
        WindowStartupLocation="CenterScreen" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent"
        ResizeMode="CanResizeWithGrip">
    <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="8"
            BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Padding="16,12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <TextBlock Text="任务详情" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <Button x:Name="CloseBtn" Content="×" Width="24" Height="24" FontSize="16"
                            HorizontalAlignment="Right" Background="Transparent" Foreground="{DynamicResource TextTertiaryBrush}"
                            BorderThickness="0" Cursor="Hand" Click="CloseBtn_Click"/>
                </Grid>
            </Border>
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,12">
                <StackPanel>
                    <CheckBox x:Name="IsCompleted" FontSize="13" Margin="0,0,0,8"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              Checked="Completed_Changed" Unchecked="Completed_Changed"/>
                    <TextBlock x:Name="Title" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10"/>
                    <Border x:Name="StatusBadge" CornerRadius="10" Padding="8,2"
                            Background="{DynamicResource AccentSoftBrush}" HorizontalAlignment="Left" Margin="0,0,0,10">
                        <TextBlock x:Name="StatusText" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBrush}"/>
                    </Border>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="优先级: " FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}"/>
                        <TextBlock x:Name="PriorityText" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                    <StackPanel x:Name="DueDateRow" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="截止: " FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}"/>
                        <TextBlock x:Name="DueDateText" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                    <TextBlock Text="进度" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="ProgressSlider" Grid.Column="0" Minimum="0" Maximum="100"
                                TickFrequency="10" IsSnapToTickEnabled="True" TickPlacement="None"
                                Style="{StaticResource ModernSlider}" ValueChanged="ProgressSlider_Changed"/>
                        <TextBlock x:Name="ProgressText" Grid.Column="1" Text="0%" Width="36"
                                   TextAlignment="Right" FontSize="11" Margin="8,0,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    </Grid>
                    <TextBlock Text="描述" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBox x:Name="DescriptionBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="64"
                             FontSize="12" Padding="10" Margin="0,0,0,12"
                             Background="{DynamicResource BgSunkenBrush}"
                             BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             CaretBrush="{DynamicResource AccentBrush}"
                             LostFocus="Description_LostFocus"/>
                    <TextBlock x:Name="SubTasksHeader" Text="子任务" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" Visibility="Collapsed"/>
                    <StackPanel x:Name="SubTasksList" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,6">
                        <Button x:Name="AddSubBtn" Content="添加子任务" Padding="10,4" FontSize="11" Style="{StaticResource BtnPrimary}" Click="AddSub_Click"/>
                        <Button x:Name="TrashBtn" Content="废弃" Padding="10,4" FontSize="11" Style="{StaticResource OutlineButton}" Foreground="{DynamicResource DangerBrush}" BorderBrush="{DynamicResource DangerBrush}" Margin="8,0,0,0" Click="TrashBtn_Click"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
            <Border x:Name="FooterBorder" Grid.Row="2" Padding="16,10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="DeleteBtn" Content="删除" Padding="12,6" FontSize="12" Style="{StaticResource OutlineButton}" Foreground="{DynamicResource DangerBrush}" BorderBrush="{DynamicResource DangerBrush}" Click="DeleteBtn_Click" Visibility="Collapsed"/>
                    <Button x:Name="RestoreBtn" Content="恢复" Padding="12,6" FontSize="12" Style="{StaticResource BtnPrimary}" Margin="8,0,0,0" Visibility="Collapsed" Click="RestoreBtn_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
