<Window x:Class="ToolBox.Views.Todo.CompactTodoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Todo" Height="240" Width="270"
        WindowStartupLocation="Manual" Topmost="True"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ShowInTaskbar="False">
    <Border x:Name="RootBorder" Background="{StaticResource BgSecondaryBrush}" CornerRadius="10"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Opacity="0.5"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title + opacity slider -->
            <Grid Grid.Row="0" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TitleText" Grid.Column="0" Text="Todo (0)"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <Slider x:Name="OpacitySlider" Grid.Column="1" Width="70"
                        Minimum="10" Maximum="100" Value="50"
                        ToolTip="背景透明度"
                        ValueChanged="OpacitySlider_Changed"/>
            </Grid>

            <ListBox x:Name="TodoList" Grid.Row="1"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <CheckBox IsChecked="{Binding IsCompleted}" VerticalAlignment="Center"
                                      Margin="0,0,6,0" Checked="Item_StatusChanged" Unchecked="Item_StatusChanged"/>
                            <TextBlock Text="{Binding Title}" FontSize="11"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Grid Grid.Row="2" Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="QuickInput" Grid.Column="0" FontSize="11" Padding="4,3"
                         KeyDown="QuickInput_KeyDown"/>
                <Button Grid.Column="1" Content="+" Width="28" Height="24" FontSize="14" Margin="6,0,0,0"
                        Style="{StaticResource BtnDefault}" Click="AddBtn_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>
