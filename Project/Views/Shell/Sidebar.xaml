<UserControl x:Class="ToolBox.Views.Shell.Sidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="64">
    <UserControl.Resources>
        <Style x:Key="NavItemStyle" TargetType="RadioButton">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="8,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{DynamicResource SidebarTextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <Border x:Name="activeBar" Width="3" HorizontalAlignment="Left"
                                    Background="Transparent" CornerRadius="2" Margin="-8,0,0,0"/>
                            <Border x:Name="bg" Background="Transparent" CornerRadius="{StaticResource RadiusSm}">
                                <Grid>
                                    <TextBlock x:Name="icon" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                               Foreground="{TemplateBinding Foreground}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Text="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"/>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource SidebarHoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource SidebarTextActiveBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="activeBar" Property="Background" Value="{DynamicResource SidebarAccentBrush}"/>
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource SidebarHoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource SidebarTextActiveBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Border Background="{DynamicResource SidebarBgBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Width="36" Height="36" Margin="0,16,0,24"
                    CornerRadius="8" Background="{DynamicResource AccentBrush}">
                <TextBlock Text="T" Foreground="White" FontWeight="Bold" FontSize="18"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel Grid.Row="1" Margin="0,0,0,16">
                <RadioButton x:Name="NavDashboard" GroupName="Nav" IsChecked="True"
                             Style="{StaticResource NavItemStyle}" Tag="&#xE80F;" Checked="OnNavChecked"/>
                <RadioButton x:Name="NavAssistant" GroupName="Nav"
                             Style="{StaticResource NavItemStyle}" Tag="&#xE8BD;" Checked="OnNavChecked"/>
                <RadioButton x:Name="NavTodos" GroupName="Nav"
                             Style="{StaticResource NavItemStyle}" Tag="&#xE9D5;" Checked="OnNavChecked"/>
                <RadioButton x:Name="NavScreenshots" GroupName="Nav"
                             Style="{StaticResource NavItemStyle}" Tag="&#xE722;" Checked="OnNavChecked"/>
                <RadioButton x:Name="NavClipboard" GroupName="Nav"
                             Style="{StaticResource NavItemStyle}" Tag="&#xE77F;" Checked="OnNavChecked"/>
                <RadioButton x:Name="NavSnippets" GroupName="Nav"
                             Style="{StaticResource NavItemStyle}" Tag="&#xE9CE;" Checked="OnNavChecked"/>
                <RadioButton x:Name="NavSettings" GroupName="Nav"
                             Style="{StaticResource NavItemStyle}" Tag="&#xE713;" Checked="OnNavChecked"/>
            </StackPanel>
            <TextBlock Grid.Row="2" Text="v2.0" FontSize="10"
                       Foreground="{DynamicResource SidebarTextBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,12" Opacity="0.6"/>
        </Grid>
    </Border>
</UserControl>
