<Window x:Class="ToolBox.Views.CloseDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="关闭" Width="360" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="NoResize" ShowInTaskbar="False"
        Background="Transparent">
    <Border Background="{DynamicResource BgElevatedBrush}"
            BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1"
            CornerRadius="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="8" Opacity="0.2" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="{DynamicResource BgElevatedBrush}" CornerRadius="8,8,0,0"
                    BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="OnTitleBarMouseDown">
                <Grid Margin="16,0">
                    <TextBlock x:Name="TitleText" Text="关闭 ToolBox" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <Button Grid.Column="1" Width="28" Height="28" Style="{StaticResource IconButton}"
                            Click="OnCancelClick" Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                            HorizontalAlignment="Right" Margin="0,0,0,0"/>
                </Grid>
            </Border>
            <StackPanel Grid.Row="1" Margin="24,20,24,0">
                <TextBlock Text="请选择操作：" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="最小化到系统抽屉后仍可继续使用截图贴图功能" FontSize="11"
                           Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,6,0,0" TextWrapping="Wrap"/>
            </StackPanel>
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="24,20,24,20">
                <Button x:Name="BtnMinimize" Content="最小化到系统抽屉" Width="130" Height="30"
                        Style="{StaticResource BtnDefault}" Click="OnMinimizeClick" Margin="0,0,8,0"/>
                <Button x:Name="BtnExit" Content="退出" Width="72" Height="30"
                        Style="{StaticResource BtnPrimary}" Click="OnExitClick"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
