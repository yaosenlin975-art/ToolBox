<Window x:Class="ToolBox.Views.PenToolWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="画笔工具" Height="600" Width="800"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ToolBar Grid.Row="0">
            <Button Content="红" Click="BtnRed_Click" Background="Red" Foreground="White" Width="30"/>
            <Button Content="蓝" Click="BtnBlue_Click" Background="Blue" Foreground="White" Width="30"/>
            <Button Content="绿" Click="BtnGreen_Click" Background="Green" Foreground="White" Width="30"/>
            <Button Content="黑" Click="BtnBlack_Click" Background="Black" Foreground="White" Width="30"/>
            <Button Content="白" Click="BtnWhite_Click" Background="White" Width="30"/>
            <Separator/>
            <Button Content="细" Click="BtnThin_Click" Width="30"/>
            <Button Content="中" Click="BtnMedium_Click" Width="30"/>
            <Button Content="粗" Click="BtnThick_Click" Width="30"/>
            <Separator/>
            <Button Content="撤销" Click="BtnUndo_Click" Width="50"/>
            <Button Content="清除" Click="BtnClear_Click" Width="50"/>
        </ToolBar>

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <Canvas x:Name="drawCanvas" Background="White"
                    MouseLeftButtonDown="OnCanvasMouseDown"
                    MouseMove="OnCanvasMouseMove"
                    MouseLeftButtonUp="OnCanvasMouseUp"/>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button Content="保存" Click="BtnSave_Click" Width="80" Margin="0,0,5,0"/>
            <Button Content="取消" Click="BtnCancel_Click" Width="80"/>
        </StackPanel>
    </Grid>
</Window>
