<UserControl x:Class="ToolBox.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BgBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="32,24,32,8">
            <TextBlock Text="截图历史" FontSize="22" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock x:Name="lblSubtitle" Text="加载中..." FontSize="12" Margin="0,4,0,0"
                       Foreground="{DynamicResource TextTertiaryBrush}"/>
        </StackPanel>

        <!-- Toolbar -->
        <Border Grid.Row="1" Margin="32,0,32,0" Padding="0,12"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <!-- View Toggle -->
                <Border Background="{DynamicResource BgSunkenBrush}" CornerRadius="6"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="ViewGridBtn" Width="32" Height="28" Content="▦" FontSize="12"
                                Style="{StaticResource IconButton}" Click="ViewToggle_Click" Tag="grid"/>
                        <Button x:Name="ViewListBtn" Width="32" Height="28" Content="☰" FontSize="12"
                                Style="{StaticResource IconButton}" Click="ViewToggle_Click" Tag="list"/>
                    </StackPanel>
                </Border>

                <Border Width="1" Margin="10,4" Background="{DynamicResource BorderBrush}"/>

                <!-- Date Filters -->
                <Border Background="{DynamicResource BgSunkenBrush}" CornerRadius="6" Padding="2"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="DateToday" Content="今日" Style="{StaticResource DateFilterStyle}"
                                     Click="DateFilter_Changed" Margin="0,0,2,0"/>
                        <RadioButton x:Name="DateWeek" Content="本周" Style="{StaticResource DateFilterStyle}"
                                     Click="DateFilter_Changed" Margin="0,0,2,0"/>
                        <RadioButton x:Name="DateMonth" Content="本月" IsChecked="True"
                                     Style="{StaticResource DateFilterStyle}" Click="DateFilter_Changed" Margin="0,0,2,0"/>
                        <RadioButton x:Name="DateAll" Content="全部" Style="{StaticResource DateFilterStyle}"
                                     Click="DateFilter_Changed"/>
                    </StackPanel>
                </Border>

                <Border Width="1" Margin="10,4" Background="{DynamicResource BorderBrush}"/>

                <!-- Search -->
                <Border Width="200" Height="32" CornerRadius="6"
                        Background="{DynamicResource BgElevatedBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <TextBox x:Name="SearchBox" Margin="8,0" VerticalAlignment="Center"
                             FontSize="12" Background="Transparent" BorderThickness="0"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             CaretBrush="{DynamicResource AccentBrush}"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- Grid Container -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="32,16">
            <ListBox x:Name="lstHistory" Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="4"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Margin" Value="0,0,12,12"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd" Background="{DynamicResource BgElevatedBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                            CornerRadius="10" ClipToBounds="True" Cursor="Hand">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="BorderBrush"
                                                    Value="{DynamicResource BorderStrongBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Height="120" Background="{DynamicResource BgSunkenBrush}">
                                <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <StackPanel Grid.Row="1" Margin="10,8">
                                <TextBlock Text="{Binding TimeDisplay}" FontSize="11" FontWeight="Medium"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding SizeDisplay}" FontSize="10"
                                               FontFamily="{StaticResource FontMono}"
                                               Foreground="{DynamicResource TextTertiaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </ScrollViewer>

        <!-- Bottom Bar -->
        <Border Grid.Row="3" Padding="32,12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="btnLoadMore" Content="加载更多 ↓" Click="BtnLoadMore_Click"
                        Style="{StaticResource OutlineButton}" Padding="20,6" FontSize="12"
                        Visibility="Collapsed"/>
                <TextBlock x:Name="lblEmpty" Text="暂无历史记录" Margin="0,0,0,0"
                           Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12"
                           Visibility="Collapsed"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
