<UserControl x:Class="ToolBox.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BgBrush}">
    <UserControl.Resources>
        <ItemsPanelTemplate x:Key="HistoryGridPanel">
            <UniformGrid Columns="4"/>
        </ItemsPanelTemplate>
        <ItemsPanelTemplate x:Key="HistoryListPanel">
            <StackPanel Orientation="Vertical"/>
        </ItemsPanelTemplate>

        <!-- 网格视图：沿用原有卡片样式（300x200 缩略图 + 时间/尺寸） -->
        <DataTemplate x:Key="HistoryGridTemplate">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Width="300" Height="200" Background="{DynamicResource BgSunkenBrush}">
                    <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           MouseLeftButtonUp="HistoryItem_Click" MouseRightButtonDown="HistoryItem_RightClick" ToolTip="{DynamicResource Lang_Compact_ViewOriginal}"/>
                </Border>
                <StackPanel Grid.Row="1" Margin="10,8">
                    <TextBlock Text="{Binding TimeDisplay}" FontSize="11" FontWeight="Medium"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <TextBlock Text="{Binding SizeDisplay}" FontSize="10"
                                   FontFamily="{StaticResource FontMono}"
                                   Foreground="{DynamicResource TextTertiaryBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- 列表视图：横向（左侧较小缩略图 + 右侧时间/尺寸） -->
        <DataTemplate x:Key="HistoryListTemplate">
            <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="120" Height="72" Background="{DynamicResource BgSunkenBrush}">
                    <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           MouseLeftButtonUp="HistoryItem_Click" MouseRightButtonDown="HistoryItem_RightClick" ToolTip="{DynamicResource Lang_Compact_ViewOriginal}"/>
                </Border>
                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding TimeDisplay}" FontSize="12" FontWeight="Medium"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="{Binding SizeDisplay}" FontSize="10" Margin="0,2,0,0"
                               FontFamily="{StaticResource FontMono}"
                               Foreground="{DynamicResource TextTertiaryBrush}"/>
                </StackPanel>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="32,24,32,8">
            <TextBlock Text="{DynamicResource Lang_History}" FontSize="22" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock x:Name="lblSubtitle" Text="{DynamicResource Lang_Loading}" FontSize="12" Margin="0,4,0,0"
                       Foreground="{DynamicResource TextTertiaryBrush}"/>
        </StackPanel>

        <!-- Toolbar -->
        <Border Grid.Row="1" Margin="32,0,32,0" Padding="0,12"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <!-- View Toggle -->
                <Border Background="{DynamicResource BgSunkenBrush}" CornerRadius="6"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="ViewGridBtn" Width="32" Height="28" Content="▦" FontSize="12"
                                Style="{StaticResource IconButton}" Click="ViewToggle_Click" Tag="grid"/>
                        <Button x:Name="ViewListBtn" Width="32" Height="28" Content="☰" FontSize="12"
                                Style="{StaticResource IconButton}" Click="ViewToggle_Click" Tag="list"/>
                    </StackPanel>
                </Border>

                <Border Width="1" Margin="10,4" Background="{DynamicResource BorderBrush}"/>

                <!-- Date Filters -->
                <Border Background="{DynamicResource BgSunkenBrush}" CornerRadius="6" Padding="2"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="DateToday" Content="{DynamicResource Lang_DateToday}" Style="{StaticResource DateFilterStyle}"
                                     Click="DateFilter_Changed" Margin="0,0,2,0"/>
                        <RadioButton x:Name="DateWeek" Content="{DynamicResource Lang_DateWeek}" Style="{StaticResource DateFilterStyle}"
                                     Click="DateFilter_Changed" Margin="0,0,2,0"/>
                        <RadioButton x:Name="DateMonth" Content="{DynamicResource Lang_DateMonth}" IsChecked="True"
                                     Style="{StaticResource DateFilterStyle}" Click="DateFilter_Changed" Margin="0,0,2,0"/>
                        <RadioButton x:Name="DateAll" Content="{DynamicResource Lang_DateAll}" Style="{StaticResource DateFilterStyle}"
                                     Click="DateFilter_Changed"/>
                    </StackPanel>
                </Border>

                <Border Width="1" Margin="10,4" Background="{DynamicResource BorderBrush}"/>
            </StackPanel>
        </Border>

        <!-- Grid Container -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="32,16">
            <ListBox x:Name="lstHistory" Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ItemsPanel="{StaticResource HistoryGridPanel}"
                     ItemTemplate="{StaticResource HistoryGridTemplate}">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Margin" Value="0,0,12,12"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd" Background="{DynamicResource BgElevatedBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                            CornerRadius="10" ClipToBounds="True" Cursor="Hand">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="BorderBrush"
                                                    Value="{DynamicResource BorderStrongBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </ScrollViewer>

        <!-- Bottom Bar -->
        <Border Grid.Row="3" Padding="32,12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="btnLoadMore" Content="{DynamicResource Lang_LoadMore}" Click="BtnLoadMore_Click"
                        Style="{StaticResource OutlineButton}" Padding="20,6" FontSize="12"
                        Visibility="Collapsed"/>
                <TextBlock x:Name="lblEmpty" Text="{DynamicResource Lang_NoHistory}" Margin="0,0,0,0"
                           Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12"
                           Visibility="Collapsed"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
