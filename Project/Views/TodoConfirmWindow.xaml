<Window x:Class="ToolBox.Views.TodoConfirmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="待办识别结果" Width="420" Height="460"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="{DynamicResource BgPrimaryBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="识别到以下待办事项，请确认或编辑：" FontSize="13"
                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12"/>

        <ListBox x:Name="TodoListBox" Grid.Row="1" Background="Transparent" BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,0,0,6"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="{DynamicResource BgSecondaryBrush}" CornerRadius="8" Padding="10,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="13" Background="Transparent" BorderThickness="0,0,0,1"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     CaretBrush="{DynamicResource AccentBrush}"/>
                            <ComboBox Grid.Column="1" Width="60" Margin="8,0,0,0" SelectedIndex="{Binding Priority}"
                                      VerticalAlignment="Center" FontSize="11">
                                <ComboBoxItem Content="普通"/>
                                <ComboBoxItem Content="重要"/>
                                <ComboBoxItem Content="紧急"/>
                            </ComboBox>
                            <Button Grid.Column="2" Content="&#x2715;" Width="24" Height="24" Margin="6,0,0,0"
                                    FontSize="12" Background="Transparent" Foreground="{DynamicResource TextTertiaryBrush}"
                                    BorderThickness="0" Cursor="Hand" Click="RemoveItem_Click"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="+ 添加" Padding="12,6" FontSize="12" Margin="0,0,8,0"
                    Style="{StaticResource BtnDefault}" Click="AddItem_Click"/>
            <Button Content="取消" Padding="12,6" FontSize="12" Margin="0,0,8,0"
                    Style="{StaticResource BtnDefault}" Click="Cancel_Click"/>
            <Button Content="确认创建" Padding="16,6" FontSize="12"
                    Style="{StaticResource BtnPrimary}" Click="Confirm_Click"/>
        </StackPanel>
    </Grid>
</Window>
