<UserControl x:Class="ToolBox.Views.Snippets.SnippetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="24,16,24,8">
            <StackPanel>
                <TextBlock Text="📝 代码片段" FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock x:Name="lblCount" Text="共 0 条" FontSize="11"
                           Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Padding="24,0,24,8">
            <WrapPanel VerticalAlignment="Center">
                <!-- Category filter -->
                <ComboBox x:Name="cmbCategory" Width="120" Height="30" Margin="0,0,8,0"
                          SelectionChanged="CmbCategory_SelectionChanged"
                          Style="{DynamicResource {x:Type ComboBox}}"/>
                <!-- Search -->
                <Border Background="{DynamicResource BgSunkenBrush}" CornerRadius="6"
                        Padding="8,4" Width="200" Margin="0,0,8,0">
                    <TextBox x:Name="txtSearch" BorderThickness="0" Background="Transparent"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             VerticalContentAlignment="Center"
                             TextChanged="TxtSearch_TextChanged"/>
                </Border>
                <!-- New snippet button -->
                <Button Content="➕ 新建" Style="{DynamicResource BtnPrimary}"
                        Click="BtnAdd_Click" Height="30" Padding="12,0"/>
            </WrapPanel>
        </Border>

        <!-- Main: list + detail -->
        <Grid Grid.Row="2" Margin="24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <!-- Snippet list -->
            <ListBox x:Name="lstSnippets" Grid.Column="0"
                     Style="{DynamicResource ModernListBox}"
                     SelectionChanged="LstSnippets_SelectionChanged"
                     PreviewKeyDown="LstSnippets_PreviewKeyDown">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="12,8" CornerRadius="6"
                                Background="{DynamicResource BgSecondaryBrush}"
                                Margin="0,0,0,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding TriggerDisplay}" FontSize="11"
                                                   Foreground="{DynamicResource AccentBrush}" Margin="8,0,0,0"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding LanguageDisplay}" FontSize="10"
                                                   Foreground="{DynamicResource TextTertiaryBrush}" Margin="8,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding ContentPreview}" FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis" Margin="0,2,0,0"
                                               MaxHeight="32" TextWrapping="Wrap"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                        <TextBlock Text="{Binding CategoryDisplay}" FontSize="10"
                                                   Foreground="{DynamicResource TextTertiaryBrush}"/>
                                        <TextBlock Text="{Binding UseCountDisplay}" FontSize="10"
                                                   Foreground="{DynamicResource TextTertiaryBrush}" Margin="8,0,0,0"/>
                                        <TextBlock Text="{Binding UpdatedDisplay}" FontSize="10"
                                                   Foreground="{DynamicResource TextTertiaryBrush}" Margin="8,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="★" FontSize="14" Margin="4,0"
                                               Foreground="{Binding FavoriteColor}"
                                               Cursor="Hand" MouseLeftButtonDown="OnFavoriteClick"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Detail panel -->
            <Border x:Name="DetailPanel" Grid.Column="1" Margin="16,0,0,0"
                    Background="{DynamicResource BgSecondaryBrush}"
                    CornerRadius="8" Padding="16" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Name -->
                        <TextBlock Text="名称" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextTertiaryBrush}"/>
                        <TextBlock x:Name="txtDetailName" FontSize="14" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,2,0,12"
                                   TextWrapping="Wrap"/>

                        <!-- Trigger -->
                        <TextBlock Text="触发关键字" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextTertiaryBrush}"/>
                        <TextBlock x:Name="txtDetailTrigger" FontSize="13"
                                   Foreground="{DynamicResource AccentBrush}" Margin="0,2,0,12"/>

                        <!-- Category + Language -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Background="{DynamicResource BgTertiaryBrush}" CornerRadius="4" Padding="6,2">
                                <TextBlock x:Name="txtDetailCategory" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Border>
                            <Border Background="{DynamicResource BgTertiaryBrush}" CornerRadius="4" Padding="6,2" Margin="8,0,0,0">
                                <TextBlock x:Name="txtDetailLanguage" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Border>
                        </StackPanel>

                        <!-- Content -->
                        <TextBlock Text="内容" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextTertiaryBrush}"/>
                        <Border Background="{DynamicResource BgSunkenBrush}" CornerRadius="6"
                                Padding="8" Margin="0,2,0,12" MaxHeight="300">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBox x:Name="txtDetailContent" IsReadOnly="True"
                                         BorderThickness="0" Background="Transparent"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         FontFamily="{DynamicResource MonoFontFamily}"
                                         FontSize="12" TextWrapping="Wrap"/>
                            </ScrollViewer>
                        </Border>

                        <!-- Stats -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="使用次数: " FontSize="11"
                                       Foreground="{DynamicResource TextTertiaryBrush}"/>
                            <TextBlock x:Name="txtDetailUseCount" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="  创建: " FontSize="11" Margin="12,0,0,0"
                                       Foreground="{DynamicResource TextTertiaryBrush}"/>
                            <TextBlock x:Name="txtDetailCreated" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>

                        <!-- Action buttons -->
                        <WrapPanel Margin="0,4,0,0">
                            <Button Content="📋 复制内容" Style="{DynamicResource BtnDefault}"
                                    Click="BtnCopyContent_Click" Height="30" Padding="12,0" Margin="0,0,8,0"/>
                            <Button Content="✏️ 编辑" Style="{DynamicResource BtnDefault}"
                                    Click="BtnEdit_Click" Height="30" Padding="12,0" Margin="0,0,8,0"/>
                            <Button Content="🗑️ 删除" Style="{DynamicResource BtnDefault}"
                                    Click="BtnDelete_Click" Height="30" Padding="12,0"/>
                        </WrapPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Bottom bar -->
        <Border Grid.Row="3" Padding="24,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="lblStatus" FontSize="11"
                           Foreground="{DynamicResource TextTertiaryBrush}" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
