<Window x:Class="ToolBox.Views.Snippets.SnippetPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="代码片段" Width="360" Height="480"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="NoResize" ShowInTaskbar="False"
        Topmost="True" Background="Transparent"
        Deactivated="OnDeactivated" Loaded="OnLoaded">
    <Border Background="{DynamicResource BgElevatedBrush}"
            BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1"
            CornerRadius="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="8" Opacity="0.2" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Search bar -->
            <Border Grid.Row="0" Padding="12,10,12,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{DynamicResource BgSunkenBrush}" CornerRadius="6"
                            Padding="8,4">
                        <TextBox x:Name="txtSearch" BorderThickness="0" Background="Transparent"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 VerticalContentAlignment="Center"
                                 TextChanged="TxtSearch_TextChanged"
                                 PreviewKeyDown="TxtSearch_PreviewKeyDown"/>
                    </Border>
                    <Button Grid.Column="1" Content="✕" Width="24" Height="24" Margin="8,0,0,0"
                            Style="{StaticResource IconButton}" Click="OnClose"/>
                </Grid>
            </Border>

            <!-- Category filter -->
            <Border Grid.Row="1" Padding="12,0,12,4">
                <StackPanel Orientation="Horizontal">
                    <RadioButton Content="全部" IsChecked="True" Style="{StaticResource FilterTabStyle}"
                                 Checked="OnFilterChecked" Tag=""/>
                    <RadioButton Content="收藏" Style="{StaticResource FilterTabStyle}"
                                 Checked="OnFilterChecked" Tag="fav" Margin="4,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- Snippet list -->
            <ListBox x:Name="lstSnippets" Grid.Row="2" Margin="8,0"
                     Style="{DynamicResource ModernListBox}"
                     SelectionChanged="LstSnippets_SelectionChanged"
                     PreviewKeyDown="LstSnippets_PreviewKeyDown">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="10,6" CornerRadius="4" Margin="0,0,0,2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding DisplayName}" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding TriggerDisplay}" FontSize="10"
                                                   Foreground="{DynamicResource AccentBrush}" Margin="6,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding ContentPreview}" FontSize="10"
                                               Foreground="{DynamicResource TextTertiaryBrush}"
                                               TextTrimming="CharacterEllipsis" Margin="0,1,0,0"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding UseCountDisplay}" FontSize="10"
                                           Foreground="{DynamicResource TextTertiaryBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Status bar -->
            <Border Grid.Row="3" Padding="12,6" Background="{DynamicResource BgSecondaryBrush}">
                <Grid>
                    <TextBlock x:Name="lblStatus" FontSize="10"
                               Foreground="{DynamicResource TextTertiaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="Enter 展开复制 · Esc 关闭" FontSize="10"
                               Foreground="{DynamicResource TextTertiaryBrush}"
                               HorizontalAlignment="Right"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
