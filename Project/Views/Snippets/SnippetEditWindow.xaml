<Window x:Class="ToolBox.Views.Snippets.SnippetEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑代码片段" Width="520" Height="480"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="NoResize" ShowInTaskbar="False"
        Background="Transparent">
    <Border Background="{DynamicResource BgElevatedBrush}"
            BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1"
            CornerRadius="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="8" Opacity="0.2" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="{DynamicResource BgElevatedBrush}"
                  MouseLeftButtonDown="OnTitleBarMouseDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="TitleDisplay" Text="编辑代码片段" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" Margin="14,0,0,0"/>
                <Button Grid.Column="1" Width="28" Height="28" Style="{StaticResource IconButton}"
                        Click="OnClose" Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                        Margin="0,0,6,0"/>
            </Grid>

            <!-- Form -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="20,12">
                <StackPanel>
                    <!-- Name -->
                    <TextBlock Text="名称 *" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBox x:Name="txtName" Margin="0,4,0,12" Height="28" FontSize="13"
                             Background="{DynamicResource BgSunkenBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderDefaultBrush}"/>

                    <!-- Trigger -->
                    <TextBlock Text="触发关键字 (如 ;sig)" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBox x:Name="txtTrigger" Margin="0,4,0,12" Height="28" FontSize="13"
                             Background="{DynamicResource BgSunkenBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderDefaultBrush}"/>

                    <!-- Category + Language -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="分类" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBox x:Name="txtCategory" Margin="0,4,0,0" Height="28" FontSize="13"
                                     Background="{DynamicResource BgSunkenBrush}"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     BorderBrush="{DynamicResource BorderDefaultBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="语言" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <ComboBox x:Name="cmbLanguage" Margin="0,4,0,0" Height="28" FontSize="12">
                                <ComboBoxItem Content="plaintext" IsSelected="True"/>
                                <ComboBoxItem Content="csharp"/>
                                <ComboBoxItem Content="python"/>
                                <ComboBoxItem Content="javascript"/>
                                <ComboBoxItem Content="typescript"/>
                                <ComboBoxItem Content="html"/>
                                <ComboBoxItem Content="css"/>
                                <ComboBoxItem Content="sql"/>
                                <ComboBoxItem Content="json"/>
                                <ComboBoxItem Content="xml"/>
                                <ComboBoxItem Content="markdown"/>
                                <ComboBoxItem Content="bash"/>
                                <ComboBoxItem Content="powershell"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <!-- Content -->
                    <TextBlock Text="内容 *" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBox x:Name="txtContent" Margin="0,4,0,0" Height="200" FontSize="12"
                             TextWrapping="Wrap" AcceptsReturn="True" AcceptsTab="True"
                             VerticalScrollBarVisibility="Auto"
                             Background="{DynamicResource BgSunkenBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderDefaultBrush}"
                             FontFamily="{DynamicResource MonoFontFamily}"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,12,20,16">
                <Button Content="取消" Width="72" Margin="0,0,8,0"
                        Style="{StaticResource OutlineButton}" Click="OnCancel"/>
                <Button Content="保存" Width="72"
                        Style="{StaticResource BtnPrimary}" Click="OnSave"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
