<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- ToolBox Dark Theme — Nerv-inspired -->
    <!-- Surface -->
    <SolidColorBrush x:Key="BgBrush" Color="#0C0D10"/>
    <SolidColorBrush x:Key="BgElevatedBrush" Color="#141519"/>
    <SolidColorBrush x:Key="BgSunkenBrush" Color="#08090C"/>
    <SolidColorBrush x:Key="BgOverlayBrush" Color="#F2141519"/>
    <SolidColorBrush x:Key="BgHoverBrush" Color="#1C1D24"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E8ECF4"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#8B91A0"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#555B6E"/>
    <SolidColorBrush x:Key="TextInvertedBrush" Color="#0F1117"/>

    <!-- Accent -->
    <SolidColorBrush x:Key="AccentBrush" Color="#E84343"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#FF5C5C"/>
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#1AE84343"/>
    <SolidColorBrush x:Key="AccentMediumBrush" Color="#33E84343"/>

    <!-- Status -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#00D2A0"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FFC107"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#FF5252"/>
    <SolidColorBrush x:Key="InfoBrush" Color="#64B5F6"/>

    <!-- Border -->
    <SolidColorBrush x:Key="BorderDefaultBrush" Color="#222430"/>
    <SolidColorBrush x:Key="BorderStrongBrush" Color="#2D3040"/>

    <!-- Sidebar -->
    <SolidColorBrush x:Key="SidebarBgBrush" Color="#08090C"/>
    <SolidColorBrush x:Key="SidebarTextBrush" Color="#6B7280"/>
    <SolidColorBrush x:Key="SidebarTextActiveBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SidebarAccentBrush" Color="#E84343"/>
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="#0AFFFFFF"/>

    <!-- Chat -->
    <SolidColorBrush x:Key="ChatUserBgBrush" Color="#E84343"/>
    <SolidColorBrush x:Key="ChatUserTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ChatAiBgBrush" Color="#141519"/>
    <SolidColorBrush x:Key="ChatAiTextBrush" Color="#E8ECF4"/>
    <SolidColorBrush x:Key="ChatToolBgBrush" Color="#1A1030"/>
    <SolidColorBrush x:Key="ChatToolTextBrush" Color="#CE93D8"/>
    <SolidColorBrush x:Key="ChatInputBgBrush" Color="#141519"/>
    <SolidColorBrush x:Key="ChatInputBorderBrush" Color="#222430"/>

    <!-- Code syntax -->
    <SolidColorBrush x:Key="CodeBgBrush" Color="#08090C"/>
    <SolidColorBrush x:Key="CodeTextBrush" Color="#E8ECF4"/>
    <SolidColorBrush x:Key="CodeKwBrush" Color="#CE93D8"/>
    <SolidColorBrush x:Key="CodeFnBrush" Color="#64B5F6"/>
    <SolidColorBrush x:Key="CodeStrBrush" Color="#81C784"/>
    <SolidColorBrush x:Key="CodeCommentBrush" Color="#555B6E"/>
    <SolidColorBrush x:Key="CodeTypeBrush" Color="#FFD54F"/>

    <!-- Tag palette -->
    <SolidColorBrush x:Key="TagFrontendBrush" Color="#60A5FA"/>
    <SolidColorBrush x:Key="TagBackendBrush" Color="#34D399"/>
    <SolidColorBrush x:Key="TagUrgentBrush" Color="#F87171"/>
    <SolidColorBrush x:Key="TagDocsBrush" Color="#A78BFA"/>
    <SolidColorBrush x:Key="TagReviewBrush" Color="#FBBF24"/>
    <SolidColorBrush x:Key="TagDbBrush" Color="#22D3EE"/>
    <SolidColorBrush x:Key="TagDesignBrush" Color="#F472B6"/>
    <SolidColorBrush x:Key="TagTestBrush" Color="#A3E635"/>
    <SolidColorBrush x:Key="TagDeployBrush" Color="#818CF8"/>

    <!-- 旧 key 别名(向后兼容现有 XAML,值与新 key 对应) -->
    <SolidColorBrush x:Key="BgPrimaryBrush" Color="#0C0D10"/>
    <SolidColorBrush x:Key="BgSecondaryBrush" Color="#141519"/>
    <SolidColorBrush x:Key="BgTertiaryBrush" Color="#08090C"/>
    <SolidColorBrush x:Key="AccentLightBrush" Color="#1AE84343"/>
    <SolidColorBrush x:Key="AccentDarkBrush" Color="#FF5C5C"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#222430"/>
    <SolidColorBrush x:Key="BorderLightBrush" Color="#222430"/>
    <SolidColorBrush x:Key="DangerBrush" Color="#FF5252"/>
</ResourceDictionary>
