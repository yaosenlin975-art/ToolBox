<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- ToolBox Light Theme — Nerv-inspired -->
    <!-- Surface -->
    <SolidColorBrush x:Key="BgBrush" Color="#F8F9FB"/>
    <SolidColorBrush x:Key="BgElevatedBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BgSunkenBrush" Color="#F0F1F4"/>
    <SolidColorBrush x:Key="BgOverlayBrush" Color="#EBFFFFFF"/>
    <SolidColorBrush x:Key="BgHoverBrush" Color="#EEF0F4"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#0F1117"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#5C6370"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#9CA3AF"/>
    <SolidColorBrush x:Key="TextInvertedBrush" Color="#FFFFFF"/>

    <!-- Accent -->
    <SolidColorBrush x:Key="AccentBrush" Color="#D63031"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#B71C1C"/>
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#14D63031"/>
    <SolidColorBrush x:Key="AccentMediumBrush" Color="#26D63031"/>

    <!-- Status -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#00B894"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FDCB6E"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#FF4757"/>
    <SolidColorBrush x:Key="InfoBrush" Color="#74B9FF"/>

    <!-- Border -->
    <SolidColorBrush x:Key="BorderDefaultBrush" Color="#E2E4E9"/>
    <SolidColorBrush x:Key="BorderStrongBrush" Color="#D0D3DA"/>

    <!-- Sidebar (深色,两主题相近) -->
    <SolidColorBrush x:Key="SidebarBgBrush" Color="#12131A"/>
    <SolidColorBrush x:Key="SidebarTextBrush" Color="#A3A8B8"/>
    <SolidColorBrush x:Key="SidebarTextActiveBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SidebarAccentBrush" Color="#D63031"/>
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="#0FFFFFFF"/>

    <!-- Chat -->
    <SolidColorBrush x:Key="ChatUserBgBrush" Color="#D63031"/>
    <SolidColorBrush x:Key="ChatUserTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ChatAiBgBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ChatAiTextBrush" Color="#0F1117"/>
    <SolidColorBrush x:Key="ChatToolBgBrush" Color="#F3E5F5"/>
    <SolidColorBrush x:Key="ChatToolTextBrush" Color="#6A1B9A"/>
    <SolidColorBrush x:Key="ChatInputBgBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ChatInputBorderBrush" Color="#E2E4E9"/>

    <!-- Code syntax -->
    <SolidColorBrush x:Key="CodeBgBrush" Color="#F0F1F4"/>
    <SolidColorBrush x:Key="CodeTextBrush" Color="#0F1117"/>
    <SolidColorBrush x:Key="CodeKwBrush" Color="#6A1B9A"/>
    <SolidColorBrush x:Key="CodeFnBrush" Color="#1976D2"/>
    <SolidColorBrush x:Key="CodeStrBrush" Color="#2E7D32"/>
    <SolidColorBrush x:Key="CodeCommentBrush" Color="#9CA3AF"/>
    <SolidColorBrush x:Key="CodeTypeBrush" Color="#F57F17"/>

    <!-- Tag palette (待办标签) -->
    <SolidColorBrush x:Key="TagFrontendBrush" Color="#3B82F6"/>
    <SolidColorBrush x:Key="TagBackendBrush" Color="#10B981"/>
    <SolidColorBrush x:Key="TagUrgentBrush" Color="#EF4444"/>
    <SolidColorBrush x:Key="TagDocsBrush" Color="#8B5CF6"/>
    <SolidColorBrush x:Key="TagReviewBrush" Color="#F59E0B"/>
    <SolidColorBrush x:Key="TagDbBrush" Color="#06B6D4"/>
    <SolidColorBrush x:Key="TagDesignBrush" Color="#EC4899"/>
    <SolidColorBrush x:Key="TagTestBrush" Color="#84CC16"/>
    <SolidColorBrush x:Key="TagDeployBrush" Color="#6366F1"/>

    <!-- 旧 key 别名(向后兼容现有 XAML,值与新 key 对应) -->
    <SolidColorBrush x:Key="BgPrimaryBrush" Color="#F8F9FB"/>
    <SolidColorBrush x:Key="BgSecondaryBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BgTertiaryBrush" Color="#F0F1F4"/>
    <SolidColorBrush x:Key="AccentLightBrush" Color="#14D63031"/>
    <SolidColorBrush x:Key="AccentDarkBrush" Color="#B71C1C"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#E2E4E9"/>
    <SolidColorBrush x:Key="BorderLightBrush" Color="#E2E4E9"/>
    <SolidColorBrush x:Key="DangerBrush" Color="#FF4757"/>
</ResourceDictionary>
